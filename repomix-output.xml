 *  1. Hero
 *  2. 4 pillars strip
 *  3. Audience segmentation (3 cards)
 *  4. Sede map preview
 *  5. Examen categories
 *  6. Services
 *  7. Humanización (team + testimonials)
 *  8. Quality / technology / QR
 *  9. Convenios / aliados
 * 10. Footer (rendered by BaseLayout)
 *
 * TODO (design-needed): Implement full visual design for every section.
 * TODO (content-needed): Replace all placeholder text with real copy.
 * TODO (blocking-for-v1): Wire ExamSearch island once Pagefind is configured.
 * TODO (content-needed): Populate aliados logos and convenios list.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
