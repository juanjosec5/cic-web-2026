# Sanity CMS — get these from your Sanity project dashboard
SANITY_PROJECT_ID=
SANITY_DATASET=production

# Write token — needed ONLY for the one-time sedes migration script.
# Create at sanity.io → project → API → Tokens (Editor role).
# Never commit the actual token.
SANITY_API_TOKEN=

# Resend — email delivery for contact forms
RESEND_API_TOKEN=
RESEND_FROM=onboarding@resend.dev
CONTACT_EMAIL=
