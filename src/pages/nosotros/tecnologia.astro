---
/**
 * /nosotros/tecnologia — Technology page.
 *
 * TODO (content-needed): Replace placeholder list with real equipment (brands, models, capabilities).
 * TODO (content-needed): Add equipment photos.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import BackLink from '@/components/BackLink.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
---

<BaseLayout
  title="Nuestra Tecnología"
  description="CIC Laboratorios cuenta con equipos de última generación para garantizar resultados precisos y confiables."
>
  <div class="container-page">

    <Breadcrumb items={[
      { label: 'Inicio', href: '/' },
      { label: 'Nosotros', href: '/nosotros' },
      { label: 'Tecnología' },
    ]} />

    <header class="mt-6">
      <h1>Nuestra tecnología</h1>
      <p class="mt-2 text-gray-600">
        Inversión permanente en equipos y metodologías de vanguardia para ofrecer diagnósticos precisos y oportunos.
      </p>
    </header>

    <section aria-labelledby="equipos-heading" class="mt-8 card-xl">
      <h2 id="equipos-heading" class="h2-sm">
        Equipos principales
      </h2>
      <ul role="list" class="mt-4 divide-y divide-gray-100 text-sm text-gray-400">
        <li class="py-3 italic">[ Analizador hematológico — modelo pendiente ]</li>
        <li class="py-3 italic">[ Analizador de química clínica — modelo pendiente ]</li>
        <li class="py-3 italic">[ Equipo de inmunoanálisis — modelo pendiente ]</li>
      </ul>
    </section>

    <section aria-labelledby="qr-heading" class="mt-6 card-xl">
      <h2 id="qr-heading" class="h2-sm">
        Validación QR de resultados
      </h2>
      <p class="mt-4 text-sm text-gray-600">
        Cada resultado entregado incluye un código QR único que permite verificar su autenticidad en línea.
      </p>
      <a
        href="https://r2.ciclaboratorios.com:8081/VerificadorResultadosJavaEnvironment/servlet/com.verificadorresultados.webpanelprincipal"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 inline-block link-action"
      >
        Verificar un resultado →
      </a>
    </section>

    <BackLink href="/nosotros" label="Nosotros" />

  </div>
</BaseLayout>
