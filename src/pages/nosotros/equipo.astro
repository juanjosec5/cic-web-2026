---
/**
 * /nosotros/equipo — Team page.
 *
 * TODO (content-needed): Replace placeholder cards with real team members (photos, names, roles, bios).
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
---

<BaseLayout
  title="Nuestro Equipo"
  description="Conoce al equipo de profesionales de CIC Laboratorios: bacteriólogos, auxiliares de laboratorio y personal administrativo al servicio de tu salud."
>
  <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6">

    <Breadcrumb items={[
      { label: 'Inicio', href: '/' },
      { label: 'Nosotros', href: '/nosotros' },
      { label: 'Equipo' },
    ]} />

    <header class="mt-6">
      <h1>Nuestro equipo</h1>
      <p class="mt-2 text-gray-600">
        Profesionales comprometidos con la calidad analítica y la atención humanizada.
      </p>
    </header>

    <section aria-labelledby="equipo-heading" class="mt-10">
      <h2 id="equipo-heading" class="text-4xl">
        Profesionales
      </h2>

      <ul role="list" class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <li class="rounded-xl border border-gray-200 p-6">
          <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Director/a Técnico/a</p>
          <p class="mt-2 font-semibold text-gray-900">[ Nombre — pendiente ]</p>
          <p class="mt-2 text-sm italic text-gray-400">Bacteriólogo/a · Especialidad pendiente</p>
        </li>
        <li class="rounded-xl border border-gray-200 p-6">
          <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Bacteriólogo/a</p>
          <p class="mt-2 font-semibold text-gray-900">[ Nombre — pendiente ]</p>
          <p class="mt-2 text-sm italic text-gray-400">Área clínica pendiente</p>
        </li>
        <li class="rounded-xl border border-gray-200 p-6">
          <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Auxiliar de laboratorio</p>
          <p class="mt-2 font-semibold text-gray-900">[ Nombre — pendiente ]</p>
          <p class="mt-2 text-sm italic text-gray-400">Sede pendiente</p>
        </li>
      </ul>
    </section>

    <div class="mt-12 rounded-xl bg-gray-50 p-6">
      <a href="/nosotros" class="text-sm font-medium text-red-600 hover:text-red-700 transition-colors duration-200">
        ← Volver a Nosotros
      </a>
    </div>

  </div>
</BaseLayout>
