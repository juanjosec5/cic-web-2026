---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import HeroIcon from '@/components/HeroIcon.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const aliados = await getCollection('aliados');

const anchorLinks = [
  { id: 'mision', label: 'Misión' },
  { id: 'vision', label: 'Visión' },
  { id: 'historia', label: 'Historia' },
  { id: 'valores', label: 'Valores' },
  { id: 'tecnologia', label: 'Tecnología' },
  { id: 'aliados', label: 'Aliados' },
];

const valores = [
  {
    nombre: 'Amor por el trabajo',
    metafora: 'Somos como el corazón, inyectamos fuerzas para lograr desempeños superiores.',
    icono: 'M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z',
  },
  {
    nombre: 'Oportunidad',
    metafora: 'Somos como los glóbulos blancos, actuamos en el lugar y momento adecuado.',
    icono: 'M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    nombre: 'Innovación permanente',
    metafora: 'Somos como los pulmones, transformamos ideas en hechos y servicios de mejora continua.',
    icono: 'M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18',
  },
  {
    nombre: 'Calidez',
    metafora: 'Somos como el algodón en el trato a nuestros usuarios.',
    icono: 'M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z',
  },
  {
    nombre: 'Compromiso y respeto',
    metafora: 'Somos como los elementos de protección personal, aportamos conocimiento para el beneficio de todos.',
    icono: 'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z',
  },
  {
    nombre: 'Confiabilidad y transparencia',
    metafora: 'Somos como el microscopio, ampliamos nuestros objetivos para generar tranquilidad.',
    icono: 'M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 15.803 7.5 7.5 0 0016.803 15.803z',
  },
];
---

<BaseLayout
  title="Nosotros"
  description="Conoce la misión, visión, historia y valores de CIC Laboratorios, referente en diagnóstico clínico en el Valle del Cauca."
>
  <div class="container-page">
    <Breadcrumb items={[{ label: 'Inicio', href: '/' }, { label: 'Nosotros' }]} />

    <div class="flex flex-col gap-10 md:flex-row md:gap-12">

      <!-- Sticky anchor nav (desktop only) -->
      <aside class="shrink-0 md:w-44">
        <nav
          aria-label="Secciones de Nosotros"
          class="md:sticky md:top-20 md:self-start"
        >
          <p class="hidden md:block mb-2 text-xs font-semibold uppercase tracking-widest text-gray-400">Contenido</p>
          <ol class="border-l-2 border-gray-200 pl-3 space-y-1">
            {anchorLinks.map((link) => (
              <li>
                <a
                  href={`#${link.id}`}
                  class="block py-1 text-sm text-gray-500 hover:text-red-700 transition-colors duration-150"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ol>
        </nav>
      </aside>

      <!-- Main content -->
      <div class="flex-1 space-y-16">

        <!-- Misión -->
        <section id="mision" aria-labelledby="mision-heading">
          <h2 id="mision-heading">Misión</h2>
          <p class="mt-4 text-gray-700 leading-relaxed">
            Somos una organización del sector de la salud dedicada al procesamiento y análisis de exámenes de
            Laboratorio Clínico, atendiendo amable y profesionalmente a los pacientes de las EPS, Hospitales,
            Clínicas, Particulares y demás entidades de la Salud, con tecnología y equipos de última generación,
            entregando información en tiempo real en todas nuestras sedes, comprometidos con la calidad de vida
            para el Valle del Cauca.
          </p>
        </section>

        <!-- Visión -->
        <section id="vision" aria-labelledby="vision-heading">
          <h2 id="vision-heading">Visión</h2>
          <p class="mt-4 text-gray-700 leading-relaxed">
            Ser al 2027 líder en el procesamiento y análisis de exámenes de laboratorio Clínico en diferentes
            niveles de complejidad, logrando ampliar nuestra cobertura del suroccidente Colombiano a un alcance
            nacional e internacional para el beneficio de nuestros aliados, pacientes, colaboradores y socios.
          </p>
        </section>

        <!-- Historia -->
        <section id="historia" aria-labelledby="historia-heading">
          <h2 id="historia-heading">Historia</h2>
          <p class="mt-4 text-gray-700 leading-relaxed">
            Desde 1985 hasta hoy, CIC Laboratorios ha crecido de una sede en Guadalajara de Buga a más de 18
            sedes en el Valle del Cauca.
          </p>
          <p class="mt-3 text-gray-700 leading-relaxed">
            Cuatro décadas de crecimiento sostenido, inversión en tecnología y compromiso con el bienestar de
            nuestros pacientes han convertido a CIC en el referente de diagnóstico clínico de la región.
          </p>
          <a href="/nosotros/historia" class="mt-4 inline-block link-action">
            Ver historia completa →
          </a>
        </section>

        <!-- Valores -->
        <section id="valores" aria-labelledby="valores-heading">
          <h2 id="valores-heading">Valores</h2>
          <div class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {valores.map((valor) => (
              <div class="rounded-lg border border-gray-200 p-5">
                <HeroIcon path={valor.icono} class="mb-3 h-8 w-8 text-red-600" />
                <h3 class="text-4xl">{valor.nombre}</h3>
                <p class="mt-2 text-sm text-gray-600 leading-relaxed">{valor.metafora}</p>
              </div>
            ))}
          </div>
        </section>

        <section id="tecnologia" aria-labelledby="tecnologia-heading">
          <h2 id="tecnologia-heading">Tecnología</h2>
          <p>
            {/* TODO (content-needed): Replace with real equipment / technology copy */}
            Operamos con equipos de última generación que garantizan precisión
            en cada resultado.
          </p>
          {/* TODO (content-needed): Add equipment video embed */}
          <div
            class="mt-6 aspect-video w-full"
            role="img"
            aria-label="Video de equipos — pendiente"
          >
            [ Video de equipos — pendiente ]
          </div>
        </section>

        <section id="aliados" aria-labelledby="aliados-heading">
          <h2 id="aliados-heading">Aliados</h2>
          {aliados.length > 0 ? (
            <ul role="list" class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4">
              {aliados.map((aliado: CollectionEntry<'aliados'>) => (
                <li>
                  {aliado.data.url ? (
                    <a href={aliado.data.url} target="_blank" rel="noopener noreferrer">
                      {aliado.data.nombre}
                    </a>
                  ) : (
                    <span>{aliado.data.nombre}</span>
                  )}
                  <p>{aliado.data.descripcion}</p>
                </li>
              ))}
            </ul>
          ) : (
            <p class="mt-4">
              {/* TODO (content-needed): Add aliados entries to collection */}
              [ Lista de aliados — pendiente ]
            </p>
          )}
        </section>

      </div>
    </div>
  </div>
</BaseLayout>
