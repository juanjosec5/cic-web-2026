---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BackLink from '@/components/BackLink.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const aliados = await getCollection('aliados');
---

<BaseLayout
  title="Aliados y Convenios"
  description="Conoce los aliados estratégicos y convenios de CIC Laboratorios con EPS, ARL, clínicas y laboratorios de la región."
>
  <div class="container-page">

    <Breadcrumb items={[
      { label: 'Inicio', href: '/' },
      { label: 'Nosotros', href: '/nosotros' },
      { label: 'Aliados' },
    ]} />

    <header class="mt-6">
      <h1>Aliados y convenios</h1>
      <p class="mt-2 text-gray-600">
        Trabajamos con instituciones y organismos que comparten nuestro compromiso con la salud.
      </p>
    </header>

    {aliados.length > 0 && (
      <section aria-labelledby="aliados-heading" class="mt-8">
        <h2 id="aliados-heading" class="h2-sm">
          Aliados estratégicos
        </h2>
        <ul role="list" class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-2">
          {aliados.map((aliado: CollectionEntry<'aliados'>) => (
            <li class="card-xl">
              <p class="font-semibold text-gray-900">{aliado.data.nombre}</p>
              {aliado.data.descripcion && (
                <p class="mt-2 text-sm text-gray-600">{aliado.data.descripcion}</p>
              )}
              {aliado.data.url && (
                <a
                  href={aliado.data.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-3 inline-block link-action"
                >
                  Visitar sitio web →
                </a>
              )}
            </li>
          ))}
        </ul>
      </section>
    )}

    <section aria-labelledby="convenios-heading" class="mt-8 card-xl">
      <h2 id="convenios-heading" class="h2-sm">Convenios activos</h2>
      <p class="mt-2 text-sm text-gray-500">Atendemos afiliados y usuarios de las siguientes entidades.</p>

      {[
        {
          categoria: 'ARL',
          items: ['Seguros de Vida Suramericana SA — ARL'],
        },
        {
          categoria: 'EPS',
          items: [
            'Caja de Compensación Familiar Delvalle del Cauca — Comfenalco Valle',
            'Servicio Occidental de Salud — SOS',
          ],
        },
        {
          categoria: 'IPS',
          items: [
            'Atención Médico Inmediata Domiciliaria — AMID SAS',
            'Centro Médico y Estético Kirei',
            'Clínica Sane',
            'Reumatología del Valle S.A.S.',
            'Soluciones Médicas en Casa S.A.S.',
            'Vitavi IPS — Strategos Medical Solutions',
          ],
        },
        {
          categoria: 'Cooperativas, Fondos y Sindicatos',
          items: [
            'Cootraipi — Asociados',
            'Cofincafe — Trabajador',
            'Cofincafe — Asociado',
            'Cootraunión — Asociados',
            'Coprocenva Cooperativa de Ahorro y Crédito',
            'FASTEMCA — Crédito',
            'Sindicato de Empleados de Guadalajara de Buga',
            'Fondo de Empleados de Aguas de Buga',
          ],
        },
        {
          categoria: 'Empresas',
          items: [
            'Cecilia Payán S.A. / Dulces del Valle S.A.',
            'Centro de Bienestar del Anciano de Buga',
            'Centro Integral Naturópático — Dr. Omar Castro',
            'Centro Médico y Estético Kirei',
            'Clínica Visión Cabal',
            'Control Medic SAS',
            'Dacare IPS SAS — Particulares',
            'Grasas S.A. / Alianza Team — Trabajadores y Contratistas',
            'Instituto Técnico Colombiano — INTEC Cartago (Estudiantes)',
            'Super Servicios del Centro Valle S.A. — Trabajadores',
            'Universidad del Valle — Estudiantes y Trabajadores',
          ],
        },
        {
          categoria: 'Tarjetas de Membresías',
          items: [
            'Benefiser',
            'Médica Familiar del Valle',
            'Organización Progresar Tuluá',
            'Proeval',
            'Previser',
            'Tservimos',
            'Renaser VIP',
            'Servifamiliar',
            'Soy Sentir Humano SAS — Humanizar / Grupo Sentir',
          ],
        },
        {
          categoria: 'Medicina Prepagada',
          items: [
            'Allianz Seguros de Vida S.A.',
            'Colmédica',
            'Colsanitas Integral',
            'Coomeva Medicina Prepagada',
            'SOS Bienestar',
            'Suramericana Prepagada',
            'Suramericana / Suramericana Ingresos',
          ],
        },
      ].map(({ categoria, items }) => (
        <div class="mt-6 first:mt-4">
          <h3 class="text-sm font-semibold uppercase tracking-widest text-gray-400">{categoria}</h3>
          <ul role="list" class="mt-3 flex flex-wrap gap-2">
            {items.map((item) => (
              <li>
                <span class="inline-flex items-center rounded-full border border-gray-200 bg-white px-3 py-1 text-sm font-medium text-gray-700">
                  {item}
                </span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </section>

    <BackLink href="/nosotros" label="Nosotros" />

  </div>
</BaseLayout>
