---
/**
 * /nosotros/calidad — Quality and certifications page.
 *
 * TODO (content-needed): Add real accreditation numbers, dates, auditing bodies.
 * TODO (content-needed): Add downloadable quality policy PDF.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
---

<BaseLayout
  title="Calidad y Certificaciones"
  description="CIC Laboratorios cumple con los más altos estándares de calidad en el diagnóstico clínico. Conozca nuestras certificaciones y política de calidad."
>
  <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6">

    <Breadcrumb items={[
      { label: 'Inicio', href: '/' },
      { label: 'Nosotros', href: '/nosotros' },
      { label: 'Calidad' },
    ]} />

    <header class="mt-6">
      <h1 class="text-2xl font-bold sm:text-3xl">Calidad y certificaciones</h1>
      <p class="mt-2 text-gray-600">
        Resultados confiables respaldados por procesos de control rigurosos y acreditaciones reconocidas.
      </p>
    </header>

    <section aria-labelledby="acreditacion-heading" class="mt-8 rounded-xl border border-gray-200 p-6">
      <h2 id="acreditacion-heading" class="text-xs font-medium uppercase tracking-wide text-gray-500">
        Acreditación
      </h2>
      <p class="mt-4 text-sm text-gray-400 italic">
        Detalles de acreditación ICONTEC — número y alcance pendientes.
      </p>
    </section>

    <section aria-labelledby="control-calidad-heading" class="mt-6 rounded-xl border border-gray-200 p-6">
      <h2 id="control-calidad-heading" class="text-xs font-medium uppercase tracking-wide text-gray-500">
        Control de calidad interno y externo
      </h2>
      <p class="mt-4 text-sm text-gray-400 italic">
        Descripción de programas EQAS y procesos de control de calidad — pendiente.
      </p>
    </section>

    <section aria-labelledby="politica-heading" class="mt-6 rounded-xl border border-gray-200 p-6">
      <h2 id="politica-heading" class="text-xs font-medium uppercase tracking-wide text-gray-500">
        Política de calidad
      </h2>
      <p class="mt-4 text-sm text-gray-400 italic">
        Texto oficial de política de calidad — pendiente.
      </p>
    </section>

    <div class="mt-12 rounded-xl bg-gray-50 p-6">
      <a href="/nosotros" class="text-sm font-medium text-navy-700 hover:text-navy-600 transition-colors duration-200">
        ← Volver a Nosotros
      </a>
    </div>

  </div>
</BaseLayout>
