---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { SITE_CONFIG } from '@/lib/config';

const [sedes, examenes] = await Promise.all([
  getCollection('sedes'),
  getCollection('examenes', ({ data }: CollectionEntry<'examenes'>) => data.activo),
]);

const WA_MESSAGE_ALIANZA = 'Quisiera información sobre alianzas con CIC Laboratorios.';
const waAlianza = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent(WA_MESSAGE_ALIANZA)}`;
---

<BaseLayout
  title="Alianzas con Laboratorios e IPS"
  description="CIC Laboratorios como laboratorio de referencia para IPS y laboratorios clínicos de la región. Referencia de muestras especializadas."
  whatsappMessage={WA_MESSAGE_ALIANZA}
>
  <div class="container-page">

    <Breadcrumb items={[{ label: 'Inicio', href: '/' }, { label: 'Laboratorios aliados' }]} />

    <header>
      <h1>Alianzas con laboratorios e IPS</h1>
      <p>
        {/* TODO (content-needed): Replace with real intro copy */}
        CIC Laboratorios actúa como laboratorio de referencia regional para IPS y
        laboratorios clínicos que necesiten envío de muestras especializadas.
      </p>
    </header>

    <!-- Differentiator cards -->
    <section aria-labelledby="diferenciadores-heading" class="mt-12">
      <h2 id="diferenciadores-heading" class="sr-only">Por qué elegirnos</h2>
      <ul role="list" class="grid grid-cols-1 gap-6 md:grid-cols-3">
        <li>
          <article class="card">
            <h3>Cobertura regional</h3>
            <p class="mt-2 text-sm text-gray-600">
              {sedes.length} sedes activas en el Valle del Cauca para
              recepción y despacho de muestras.
            </p>
          </article>
        </li>
        <li>
          <article class="card">
            <h3>Portafolio amplio</h3>
            <p class="mt-2 text-sm text-gray-600">
              {examenes.length} exámenes disponibles — desde rutinas básicas
              hasta pruebas de alta complejidad.
            </p>
          </article>
        </li>
        <li>
          <article class="card">
            <h3>Recolección diaria</h3>
            <p class="mt-2 text-sm text-gray-600">
              {/* TODO (content-needed): Describe recolección / transporte process */}
              Rutas de recolección de muestras con trazabilidad completa.
            </p>
          </article>
        </li>
      </ul>
    </section>

    <!-- CTA — form mockup (submission not yet wired) -->
    <section aria-labelledby="alianza-cta-heading" class="mt-12">
      <h2 id="alianza-cta-heading">Proponer una alianza</h2>
      <p class="mt-2 text-gray-600">Complete el formulario y un especialista se comunicará con usted.</p>

      <div class="mt-6 rounded-lg border border-gray-200 bg-white p-8">
        <form action="#" method="POST" class="grid grid-cols-1 gap-6 sm:grid-cols-2">

          <!-- Honeypot — hidden from humans, traps bots -->
          <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />

          <div>
            <label for="organizacion" class="block text-sm font-medium text-gray-700 mb-1">
              Nombre de la organización <span class="text-red-500">*</span>
            </label>
            <input
              type="text" id="organizacion" name="organizacion" required
              class="form-input"
              placeholder="IPS Regional S.A.S."
            />
          </div>

          <div>
            <label for="tipo" class="block text-sm font-medium text-gray-700 mb-1">
              Tipo de organización <span class="text-red-500">*</span>
            </label>
            <select
              id="tipo" name="tipo" required
              class="form-input bg-white"
            >
              <option value="" disabled selected>Seleccionar tipo…</option>
              <option value="ips">IPS</option>
              <option value="laboratorio-clinico">Laboratorio clínico</option>
              <option value="centro-medico">Centro médico</option>
              <option value="clinica">Clínica</option>
              <option value="otro">Otro</option>
            </select>
          </div>

          <div>
            <label for="nombre" class="block text-sm font-medium text-gray-700 mb-1">
              Nombre del contacto <span class="text-red-500">*</span>
            </label>
            <input
              type="text" id="nombre" name="nombre" required
              class="form-input"
              placeholder="Dr. Juan Pérez"
            />
          </div>

          <div>
            <label for="cargo" class="block text-sm font-medium text-gray-700 mb-1">
              Cargo
            </label>
            <input
              type="text" id="cargo" name="cargo"
              class="form-input"
              placeholder="Director Médico"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
              Correo electrónico <span class="text-red-500">*</span>
            </label>
            <input
              type="email" id="email" name="email" required
              class="form-input"
              placeholder="contacto@ips.com"
            />
          </div>

          <div>
            <label for="telefono" class="block text-sm font-medium text-gray-700 mb-1">
              Teléfono <span class="text-red-500">*</span>
            </label>
            <input
              type="tel" id="telefono" name="telefono" required
              class="form-input"
              placeholder="310 000 0000"
            />
          </div>

          <div class="sm:col-span-2">
            <label for="ciudad" class="block text-sm font-medium text-gray-700 mb-1">
              Ciudad / Municipio de operación <span class="text-red-500">*</span>
            </label>
            <input
              type="text" id="ciudad" name="ciudad" required
              class="form-input"
              placeholder="Ej: Buga, Tuluá, Cali…"
            />
          </div>

          <div class="sm:col-span-2">
            <fieldset>
              <legend class="block text-sm font-medium text-gray-700 mb-2">
                Servicios de interés <span class="text-red-500">*</span>
              </legend>
              <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                {[
                  'Referencia de muestras',
                  'Educación continuada',
                  'Perfil de precios especial',
                  'Otro',
                ].map((s) => (
                  <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                    <input
                      type="checkbox" name="servicio[]" value={s}
                      class="h-4 w-4 rounded border-gray-300 text-red-600 focus:ring-red-500"
                    />
                    {s}
                  </label>
                ))}
              </div>
            </fieldset>
          </div>

          <div class="sm:col-span-2">
            <label for="mensaje" class="block text-sm font-medium text-gray-700 mb-1">
              Descripción de la alianza propuesta
            </label>
            <textarea
              id="mensaje" name="mensaje" rows={4}
              class="form-input resize-none"
              placeholder="Cuéntenos sobre su organización y qué tipo de alianza busca…"
            ></textarea>
          </div>

          <div class="sm:col-span-2">
            <button
              type="submit"
              aria-disabled="true"
              aria-describedby="submit-hint-alianza"
              onclick="event.preventDefault()"
              class="w-full rounded-lg bg-red-600 px-6 py-3 text-sm font-semibold text-white shadow-sm opacity-50 cursor-not-allowed"
            >
              Enviar propuesta
            </button>
            <p id="submit-hint-alianza" class="mt-2 text-center text-xs text-gray-400">El envío estará disponible próximamente.</p>
          </div>

        </form>
      </div>

      <!-- Secondary fallbacks -->
      <div class="mt-6 flex flex-col gap-2 sm:flex-row sm:items-center sm:gap-4">
        <span class="text-sm text-gray-400">O contáctenos directamente:</span>
        <a href={waAlianza} target="_blank" rel="noopener noreferrer"
           class="text-sm font-medium text-green-600 hover:text-green-700 transition-colors duration-200">
          WhatsApp →
        </a>
        <a href="mailto:alianzas@ciclaboratorios.com?subject=Propuesta%20de%20alianza"
           class="text-sm font-medium text-gray-500 hover:text-red-700 transition-colors duration-200">
          alianzas@ciclaboratorios.com →
        </a>
      </div>
    </section>

  </div>
</BaseLayout>
