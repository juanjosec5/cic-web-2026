---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { SITE_CONFIG } from '@/lib/config';
import { client } from '@/sanity/client';
import { ALL_SEDES_QUERY } from '@/sanity/queries';
import type { Sede } from '@/sanity/types';

const [sedes, examenes] = await Promise.all([
  client.fetch<Sede[]>(ALL_SEDES_QUERY),
  getCollection('examenes', ({ data }: CollectionEntry<'examenes'>) => data.activo),
]);

const WA_MESSAGE_ALIANZA = 'Quisiera información sobre alianzas con CIC Laboratorios.';
const waAlianza = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent(WA_MESSAGE_ALIANZA)}`;
---

<BaseLayout
  title="Laboratorio de referencia para IPS y otros laboratorios"
  description="CIC Laboratorios actúa como laboratorio de referencia para IPS y laboratorios clínicos que necesitan servicio de muestras especializadas."
  whatsappMessage={WA_MESSAGE_ALIANZA}
>
  <div class="container-page">

    <Breadcrumb items={[{ label: 'Inicio', href: '/' }, { label: 'Laboratorios de referencia' }]} />

    <header>
      <h1>Laboratorio de referencia para IPS y otros laboratorios</h1>
      <p>
        CIC Laboratorios actúa como laboratorio de referencia para IPS y
        laboratorios clínicos que necesitan servicio de muestras especializadas.
      </p>
    </header>

    <!-- Differentiator cards -->
    <section aria-labelledby="diferenciadores-heading" class="mt-12">
      <h2 id="diferenciadores-heading" class="sr-only">Por qué elegirnos</h2>
      <ul role="list" class="grid grid-cols-1 gap-6 md:grid-cols-3">
        <li>
          <article class="card">
            <h3 class="text-4xl">Cobertura regional</h3>
            <p class="mt-2 text-sm text-gray-600">
              {sedes.length} sedes activas en el Valle del Cauca para
              recepción y despacho de muestras.
            </p>
          </article>
        </li>
        <li>
          <article class="card">
            <h3 class="text-4xl">Portafolio amplio</h3>
            <p class="mt-2 text-sm text-gray-600">
              {/* TODO (content-needed): Confirm exact count and level breakdown with Sandra */}
              660+ exámenes disponibles desde Niveles I, II y III.
            </p>
          </article>
        </li>
        <li>
          <article class="card">
            <h3 class="text-4xl">Recolección diaria</h3>
            <p class="mt-2 text-sm text-gray-600">
              {/* TODO (content-needed): Describe recolección / transporte process */}
              Rutas de recolección de muestras con trazabilidad completa.
            </p>
          </article>
        </li>
      </ul>
    </section>

    <!-- CTA — form mockup (submission not yet wired) -->
    <section aria-labelledby="alianza-cta-heading" class="mt-12">
      <h2 id="alianza-cta-heading">Solicita información</h2>
      <p class="mt-2 text-gray-600">Complete el formulario y nos pondremos en contacto.</p>

      {/* TODO: Re-enable form once Resend DNS is confirmed working */}
      <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 px-6 py-8 text-center">
        <p class="text-sm font-semibold text-amber-800">Formulario temporalmente no disponible</p>
        <p class="mt-1 text-sm text-amber-700">Estamos configurando el sistema de envío. Por favor contáctenos directamente por los canales de abajo.</p>
      </div>

      <!-- Secondary fallbacks -->
      <div class="mt-6 flex flex-col gap-2 sm:flex-row sm:items-center sm:gap-4">
        <span class="text-sm text-gray-400">O contáctenos directamente:</span>
        <a href={waAlianza} target="_blank" rel="noopener noreferrer"
           class="text-sm font-medium text-green-600 hover:text-green-700 transition-colors duration-200">
          WhatsApp →
        </a>
        <a href="mailto:comercial3@ciclaboratorios.com?subject=Propuesta%20de%20alianza"
           class="text-sm font-medium text-gray-500 hover:text-red-700 transition-colors duration-200">
          comercial3@ciclaboratorios.com →
        </a>
      </div>
    </section>

  </div>
</BaseLayout>

