---
/**
 * /laboratorios — Landing page for IPS / lab partners.
 *
 * TODO (design-needed): Full landing page layout.
 * TODO (content-needed): Add partner requirements, process description.
 * TODO (content-needed): Add testimonials from current lab partners.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const aliados = await getCollection('aliados', ({ data }) => data.esEstrategico);
---

<BaseLayout
  title="Alianzas con Laboratorios e IPS"
  description="CIC Laboratorios como laboratorio de referencia para IPS y laboratorios clínicos de la región. Referencia de muestras especializadas."
>
  <h1>Alianzas con laboratorios e IPS</h1>
  <p>
    CIC Laboratorios actúa como laboratorio de referencia regional para IPS y
    laboratorios clínicos que necesiten envío de muestras especializadas.
  </p>

  <section aria-labelledby="aliados-estrategicos-heading">
    <h2 id="aliados-estrategicos-heading">Aliados estratégicos actuales</h2>
    <ul>
      {aliados.map((aliado) => (
        <li>
          <strong>{aliado.data.nombre}</strong>
          <p>{aliado.data.descripcion}</p>
        </li>
      ))}
    </ul>
  </section>

  <section aria-labelledby="propuesta-heading">
    <h2 id="propuesta-heading">¿Por qué referir sus muestras a CIC?</h2>
    <ul>
      <li>Amplio portafolio de más de 700 exámenes</li>
      <li>Respuesta rápida y trazabilidad de muestras</li>
      <li><!-- TODO (content-needed): Add more value propositions --></li>
    </ul>
  </section>

  <a
    href="mailto:alianzas@ciclaboratorios.com?subject=Propuesta%20de%20alianza"
  >
    Proponer alianza
    <!-- TODO (content-needed): Replace with correct email address -->
  </a>
</BaseLayout>
