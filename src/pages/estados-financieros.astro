---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';

const documentos = [
  {
    año: 2024,
    titulo: 'Estados Financieros 2024',
    descripcion: 'Balance general y estado de resultados del ejercicio fiscal 2024.',
    archivo: '/docs/estados-financieros/estados-financieros-2024.pdf',
  },
  {
    año: 2023,
    titulo: 'Estados Financieros 2023',
    descripcion: 'Balance general y estado de resultados del ejercicio fiscal 2023.',
    archivo: '/docs/estados-financieros/estados-financieros-2023.pdf',
  },
];
---

<BaseLayout
  title="Estados Financieros — CIC Laboratorios"
  description="Documentos de estados financieros anuales de CIC Laboratorios, publicados en cumplimiento de la normativa colombiana."
>
  <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6">

    <Breadcrumb items={[
      { label: 'Inicio', href: '/' },
      { label: 'Estados financieros' },
    ]} />

    <header class="mt-6">
      <h1 class="text-2xl font-bold text-gray-900 sm:text-3xl">Estados financieros</h1>
      <p class="mt-2 max-w-2xl text-gray-600">
        Información financiera anual de CIC Laboratorios publicada en cumplimiento de los
        requisitos legales establecidos por la normativa colombiana.
      </p>
    </header>

    <ul role="list" class="mt-10 space-y-4">
      {documentos.map((doc) => (
        <li class="flex flex-col gap-4 rounded-xl border border-gray-200 p-6 sm:flex-row sm:items-center sm:justify-between">
          <div class="flex items-start gap-5">
            <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-lg bg-gray-100 text-lg font-bold text-gray-700">
              {doc.año}
            </span>
            <div>
              <h2 class="text-base font-semibold text-gray-900">{doc.titulo}</h2>
              <p class="mt-0.5 text-sm text-gray-500">{doc.descripcion}</p>
            </div>
          </div>
          <div class="flex shrink-0 gap-2 sm:flex-col sm:items-end lg:flex-row">
            <a
              href={doc.archivo}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50 active:scale-95 transition-all duration-200"
            >
              Ver PDF
            </a>
            <a
              href={doc.archivo}
              download
              class="inline-flex items-center justify-center rounded-lg bg-red-600 px-4 py-2 text-sm font-semibold text-white hover:bg-red-700 active:scale-95 transition-all duration-200"
            >
              Descargar
            </a>
          </div>
        </li>
      ))}
    </ul>

    <p class="mt-10 text-xs text-gray-400">
      Documentos disponibles bajo cumplimiento normativo colombiano. Para consultas sobre esta
      información, contáctenos a
      <a href="mailto:buga@ciclaboratorios.com" class="hover:text-red-600 transition-colors">
        buga@ciclaboratorios.com
      </a>.
    </p>

  </div>
</BaseLayout>
