---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import HeroIcon from '@/components/HeroIcon.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { SITE_CONFIG } from '@/lib/config';
import { SERVICE_ICONS } from '@/lib/icons';

const [serviciosEmpresa, aliadosEstrategicos] = await Promise.all([
  getCollection(
    'servicios',
    ({ data }: CollectionEntry<'servicios'>) =>
      ['jornadas-empresariales', 'salud-ocupacional'].includes(data.slug)
  ),
  getCollection(
    'aliados',
    ({ data }: CollectionEntry<'aliados'>) => data.esEstrategico
  ),
]);

const WA_MESSAGE_EMPRESA = 'Quiero información sobre servicios empresariales de CIC Laboratorios.';
const waEmpresa = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent(WA_MESSAGE_EMPRESA)}`;

const PROPUESTA_ICONS = {
  reloj:     'M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z',
  ubicacion: 'M15 10.5a3 3 0 11-6 0 3 3 0 016 0z M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z',
  documento: 'M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z',
} as const;
---

<BaseLayout
  title="Servicios para Empresas"
  description="Salud ocupacional, jornadas empresariales y toma de muestras para empresas. CIC Laboratorios — su aliado en bienestar corporativo."
  whatsappMessage={WA_MESSAGE_EMPRESA}
>
  <div class="container-page">

    <Breadcrumb items={[{ label: 'Inicio', href: '/' }, { label: 'Empresas' }]} />

    <header>
      <h1>Soluciones para empresas</h1>
      <p>
        Acompañamos a su empresa con un laboratorio que procesa hasta 1,200 pruebas por hora, con resultados al
        correo en tiempo real y cobertura en todo el Valle del Cauca. Porque el bienestar de sus colaboradores
        impulsa el resultado de su empresa.
      </p>
    </header>

    <!-- Value proposition cards -->
    <section aria-labelledby="propuestas-heading" class="mt-12">
      <h2 id="propuestas-heading" class="sr-only">Por qué elegirnos</h2>
      <ul role="list" class="grid grid-cols-1 gap-6 md:grid-cols-3">
        <li class="flex">
          <article class="h-full w-full card">
            <HeroIcon path={PROPUESTA_ICONS.reloj} class="mb-3 h-8 w-8 text-red-600" />
            <h3 class="text-4xl">Resultados el mismo día</h3>
            <p class="mt-2 text-sm text-gray-600">Informe disponible en horas para que su colaborador regrese a su jornada sin contratiempos. Entrega digital al correo electrónico.</p>
          </article>
        </li>
        <li class="flex">
          <article class="h-full w-full card">
            <HeroIcon path={PROPUESTA_ICONS.ubicacion} class="mb-3 h-8 w-8 text-red-600" />
            <h3 class="text-4xl">Toma en sitio</h3>
            <p class="mt-2 text-sm text-gray-600">Nuestro equipo certificado se desplaza a sus instalaciones. Ideal para jornadas de ingreso, periódicos o retiro.</p>
          </article>
        </li>
        <li class="flex">
          <article class="h-full w-full card">
            <HeroIcon path={PROPUESTA_ICONS.documento} class="mb-3 h-8 w-8 text-red-600" />
            <h3 class="text-4xl">Informes consolidados</h3>
            <p class="mt-2 text-sm text-gray-600">Reporte único para Recursos Humanos con resultados de todo el grupo. Compatible con el sistema de gestión de SST.</p>
          </article>
        </li>
      </ul>
    </section>

    <!-- Services -->
    <section aria-labelledby="servicios-empresa-heading" class="mt-12">
      <h2 id="servicios-empresa-heading">Servicios disponibles</h2>
      <ul role="list" class="mt-6 grid grid-cols-1 gap-6 md:grid-cols-2">
        {serviciosEmpresa.map((s: CollectionEntry<'servicios'>) => (
          <li class="flex">
            <article class="flex h-full w-full flex-col card">
              {SERVICE_ICONS[s.data.slug] && (
                <HeroIcon path={SERVICE_ICONS[s.data.slug]} class="mb-3 h-8 w-8 text-red-600" />
              )}
              <h3 class="text-4xl">
                <a href={`/servicios/${s.data.slug}`} class="text-red-600 hover:text-red-700 transition-colors duration-200">{s.data.nombre}</a>
              </h3>
              <p class="mt-2 flex-1 text-sm text-gray-600">{s.data.descripcion}</p>
            </article>
          </li>
        ))}
      </ul>
    </section>

    <!-- Strategic allies -->
    {aliadosEstrategicos.length > 0 && (
      <section aria-labelledby="aliados-estrategicos-heading" class="mt-12">
        <h2 id="aliados-estrategicos-heading">Aliados estratégicos</h2>
        <ul role="list" class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4">
          {aliadosEstrategicos.map((aliado: CollectionEntry<'aliados'>) => (
            <li>
              {aliado.data.url ? (
                <a href={aliado.data.url} target="_blank" rel="noopener noreferrer">
                  {aliado.data.nombre}
                </a>
              ) : (
                <span>{aliado.data.nombre}</span>
              )}
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- CTA — form mockup (submission not yet wired) -->
    <section aria-labelledby="cotizacion-heading" class="mt-12">
      <h2 id="cotizacion-heading">Solicitar cotización empresarial</h2>
      <p class="mt-2 text-gray-600">Nos ponemos en contacto en menos de 24 horas hábiles.</p>

      <div class="mt-6 rounded-lg border border-gray-200 bg-white p-8">
        <form id="form-empresa" action="/api/contact" method="POST" class="grid grid-cols-1 gap-6 sm:grid-cols-2">

          <!-- Honeypot — hidden from humans, traps bots -->
          <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />

          <div>
            <label for="nombre" class="block text-sm font-medium text-gray-700 mb-1">
              Nombre del contacto <span class="text-red-500">*</span>
            </label>
            <input
              type="text" id="nombre" name="nombre" required
              class="form-input"
              placeholder="María García"
            />
          </div>

          <div>
            <label for="empresa" class="block text-sm font-medium text-gray-700 mb-1">
              Empresa / Razón social <span class="text-red-500">*</span>
            </label>
            <input
              type="text" id="empresa" name="empresa" required
              class="form-input"
              placeholder="Empresa S.A.S."
            />
          </div>

          <div>
            <label for="ciudad" class="block text-sm font-medium text-gray-700 mb-1">
              Ciudad <span class="text-red-500">*</span>
            </label>
            <select
              id="ciudad" name="ciudad" required
              class="form-input bg-white"
            >
              <option value="" disabled selected>Seleccionar ciudad…</option>
              <option value="buga">Buga</option>
              <option value="cali">Cali</option>
              <option value="palmira">Palmira</option>
              <option value="tulua">Tuluá</option>
              <option value="cartago">Cartago</option>
              <option value="buenaventura">Buenaventura</option>
              <option value="yumbo">Yumbo</option>
              <option value="jamundi">Jamundí</option>
              <option value="zarzal">Zarzal</option>
              <option value="la-union">La Unión</option>
              <option value="roldanillo">Roldanillo</option>
              <option value="sevilla">Sevilla</option>
              <option value="otra">Otra</option>
            </select>
          </div>

          <div>
            <label for="colaboradores" class="block text-sm font-medium text-gray-700 mb-1">
              Número de colaboradores <span class="text-red-500">*</span>
            </label>
            <select
              id="colaboradores" name="colaboradores" required
              class="form-input bg-white"
            >
              <option value="" disabled selected>Seleccionar rango…</option>
              <option value="1-50">1 – 50</option>
              <option value="51-200">51 – 200</option>
              <option value="201-500">201 – 500</option>
              <option value="500+">Más de 500</option>
            </select>
          </div>

          <div>
            <label for="telefono" class="block text-sm font-medium text-gray-700 mb-1">
              Teléfono / WhatsApp <span class="text-red-500">*</span>
            </label>
            <input
              type="tel" id="telefono" name="telefono" required
              class="form-input"
              placeholder="310 000 0000"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
              Correo electrónico <span class="text-red-500">*</span>
            </label>
            <input
              type="email" id="email" name="email" required
              class="form-input"
              placeholder="contacto@empresa.com"
            />
          </div>

          <div class="sm:col-span-2">
            <fieldset>
              <legend class="block text-sm font-medium text-gray-700 mb-2">
                Servicio de interés <span class="text-red-500">*</span>
              </legend>
              <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
                {[
                  'Salud ocupacional',
                  'Jornada empresarial',
                  'Toma en sede',
                  'Convenio',
                ].map((s) => (
                  <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                    <input
                      type="checkbox" name="servicio[]" value={s}
                      class="h-4 w-4 rounded border-gray-300 text-red-600 focus:ring-red-500"
                    />
                    {s}
                  </label>
                ))}
              </div>
            </fieldset>
          </div>

          <div class="sm:col-span-2">
            <label for="mensaje" class="block text-sm font-medium text-gray-700 mb-1">
              Mensaje adicional
            </label>
            <textarea
              id="mensaje" name="mensaje" rows={3}
              class="form-input resize-none"
              placeholder="Cuéntenos sobre sus necesidades…"
            ></textarea>
          </div>

          <div class="sm:col-span-2">
            <button
              id="btn-empresa"
              type="submit"
              class="w-full rounded-lg bg-red-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-red-700 active:scale-95 transition-all duration-200 disabled:opacity-60 disabled:cursor-not-allowed"
            >
              Enviar solicitud
            </button>
            <p id="msg-empresa" class="mt-2 text-center text-xs hidden"></p>
          </div>

        </form>
      </div>

      <!-- Secondary fallbacks -->
      <div class="mt-6 flex flex-col gap-2 sm:flex-row sm:items-center sm:gap-4">
        <span class="text-sm text-gray-400">O contáctenos directamente:</span>
        <a href={waEmpresa} target="_blank" rel="noopener noreferrer"
           class="text-sm font-medium text-green-600 hover:text-green-700 transition-colors duration-200">
          WhatsApp →
        </a>
        <a href="mailto:empresas@ciclaboratorios.com?subject=Solicitud%20de%20cotizaci%C3%B3n"
           class="text-sm font-medium text-gray-500 hover:text-red-700 transition-colors duration-200">
          empresas@ciclaboratorios.com →
        </a>
      </div>
    </section>

  </div>
</BaseLayout>

<script>
  const form = document.getElementById('form-empresa') as HTMLFormElement | null;
  const btn = document.getElementById('btn-empresa') as HTMLButtonElement | null;
  const msg = document.getElementById('msg-empresa') as HTMLParagraphElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!btn || !msg) return;

    btn.disabled = true;
    btn.textContent = 'Enviando…';
    msg.className = 'mt-2 text-center text-xs hidden';

    try {
      const res = await fetch('/api/contact', { method: 'POST', body: new FormData(form) });
      const json = await res.json();

      if (res.ok && json.ok) {
        msg.textContent = '¡Solicitud enviada! Nos pondremos en contacto pronto.';
        msg.className = 'mt-2 text-center text-xs text-green-600';
        form.reset();
      } else {
        throw new Error(json.error ?? 'Error desconocido');
      }
    } catch (err) {
      msg.textContent = 'Ocurrió un error al enviar. Por favor intente de nuevo.';
      msg.className = 'mt-2 text-center text-xs text-red-600';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Enviar solicitud';
      msg.classList.remove('hidden');
    }
  });
</script>
