---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { SITE_CONFIG } from '@/lib/config';

const waContacto = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent('Quisiera dejar una solicitud de atención al usuario de CIC Laboratorios.')}`;
---

<BaseLayout
  title="Política de Participación Social en Salud"
  description="Mecanismos de participación ciudadana, atención al usuario, PQRSF y asociación de usuarios de CIC Laboratorios."
>
  <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6">

    <Breadcrumb items={[
      { label: 'Inicio', href: '/' },
      { label: 'Participación social en salud' },
    ]} />

    <header class="mt-6">
      <h1 class="text-2xl sm:text-3xl">
        Política de participación social en salud
      </h1>
      <p class="mt-3 text-gray-600 max-w-2xl">
        CIC LABORATORIOS S.A.S., comprometidos con la salud de todos nuestros usuarios, adopta la política de
        participación social en salud en el marco de la normatividad vigente, con el fin de promover canales de
        comunicación que vinculen a la ciudadanía y garanticen el derecho fundamental a la participación en salud.
      </p>
    </header>

    <!-- Intro -->
    <section aria-labelledby="participacion-heading" class="mt-8 rounded-lg border border-gray-200 p-6">
      <h2 id="participacion-heading" class="text-base text-gray-900">¿Qué es la participación en salud?</h2>
      <p class="mt-3 text-sm text-gray-700 leading-relaxed">
        Es el derecho a una participación significativa de la ciudadanía en la toma de decisiones acerca de la
        salud. Su objetivo es que las personas naturales y jurídicas participen — a nivel ciudadano, comunitario,
        social e institucional — para ejercer sus derechos y deberes en salud.
      </p>
    </section>

    <!-- Mecanismos -->
    <section aria-labelledby="mecanismos-heading" class="mt-8">
      <h2 id="mecanismos-heading" class="text-lg text-gray-900">
        Mecanismos de participación ciudadana
      </h2>
      <p class="mt-2 text-sm text-gray-600">
        En CIC LABORATORIOS S.A.S. promovemos los siguientes mecanismos de participación, control social y
        protección al usuario del servicio de salud:
      </p>

      <div class="mt-6 space-y-6">

        <!-- Oficina de atención al usuario -->
        <article class="rounded-lg border border-gray-200 p-6">
          <h3 class="font-semibold text-gray-900">Oficina de atención al usuario</h3>
          <p class="mt-2 text-sm text-gray-600">
            Mejora la calidad de los servicios mediante escucha activa y comunicación asertiva, garantizando
            derechos y orientando a los usuarios.
          </p>
          <address class="mt-4 not-italic space-y-1 text-sm text-gray-700">
            <p>Sede principal: Carrera 13 # 4-51, Guadalajara de Buga</p>
            <p>Lunes a viernes: 6:30 a.m. – 12:00 m. y 2:00 p.m. – 5:00 p.m.</p>
            <p>Sábados: 7:00 a.m. – 12:00 m.</p>
            <p>
              Celular:
              <a href="tel:3158197366" class="text-navy-700 hover:text-navy-600 transition-colors">3158197366</a>
            </p>
          </address>
        </article>

        <!-- PQRSF -->
        <article class="rounded-lg border border-gray-200 p-6">
          <h3 class="font-semibold text-gray-900">PQRSF — Peticiones, quejas, reclamos, sugerencias y felicitaciones</h3>
          <p class="mt-2 text-sm text-gray-600">
            Para conocer las necesidades y expectativas de los usuarios y propender a mejorar los procesos de
            prestación del servicio, puede dejar aquí sus solicitudes de información o cualquier comunicación.
          </p>
          <div class="mt-4 flex flex-col gap-3 sm:flex-row">
            <a
              href="/contacto"
              class="inline-flex items-center justify-center rounded-lg bg-navy-800 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-navy-700 active:scale-95 transition-all duration-200"
            >
              Formulario de contacto
            </a>
            <a
              href={waContacto}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center rounded-lg border border-gray-300 bg-white px-5 py-2.5 text-sm font-semibold text-gray-700 hover:bg-gray-50 active:scale-95 transition-all duration-200"
            >
              WhatsApp →
            </a>
            <a
              href="mailto:servicioalcliente@ciclaboratorios.com"
              class="inline-flex items-center justify-center rounded-lg border border-gray-300 bg-white px-5 py-2.5 text-sm font-semibold text-gray-700 hover:bg-gray-50 active:scale-95 transition-all duration-200"
            >
              servicioalcliente@ciclaboratorios.com
            </a>
          </div>
        </article>

        <!-- Encuesta de satisfacción -->
        <article class="rounded-lg border border-gray-200 p-6">
          <h3 class="font-semibold text-gray-900">Encuesta de satisfacción</h3>
          <p class="mt-2 text-sm text-gray-600">
            La satisfacción de los usuarios es muy importante para nosotros. La encuesta de satisfacción es
            voluntaria y hace parte de nuestra estrategia de mejoramiento continuo en la prestación del servicio.
          </p>
          <p class="mt-3 text-sm text-gray-400 italic">Encuesta disponible próximamente.</p>
        </article>

        <!-- Comité de Ética -->
        <article class="rounded-lg border border-gray-200 p-6">
          <h3 class="font-semibold text-gray-900">Comité de Ética</h3>
          <p class="mt-2 text-sm text-gray-600">
            El Comité de Ética participa en programas de promoción y prevención de la salud, vela por el
            cumplimiento en la divulgación de los derechos y deberes en salud, y propone medidas que mejoran
            la oportunidad, calidad y humanización del servicio.
          </p>
        </article>

        <!-- Asociación de Usuarios -->
        <article class="rounded-lg border border-gray-200 p-6">
          <h3 class="font-semibold text-gray-900">Asociación de usuarios</h3>
          <p class="mt-2 text-sm text-gray-600">
            Espacio de carácter institucional vinculado al Sistema General de Seguridad Social en Salud (SGSSS)
            que vela por los derechos de los usuarios a disfrutar de servicios de buena calidad, trato digno y
            humanizado, y canaliza sugerencias, inquietudes, reclamos y satisfacción.
          </p>
          <div class="mt-4 rounded-lg bg-gray-50 p-4">
            <h4 class="text-sm font-medium text-gray-900">¿Quién puede ser miembro?</h4>
            <p class="mt-2 text-sm text-gray-600">
              Toda persona natural mayor de edad que haga uso de los servicios del laboratorio, participando
              libre y voluntariamente de la convocatoria. Los interesados deben contar con disponibilidad y
              compromiso para las actividades que se realicen con la Asociación de usuarios.
            </p>
          </div>
        </article>

      </div>
    </section>

    <!-- Links -->
    <section aria-labelledby="docs-relacionados-heading" class="mt-8 rounded-xl bg-gray-50 p-6">
      <h2 id="docs-relacionados-heading" class="text-sm text-gray-900">Documentos relacionados</h2>
      <ul class="mt-3 space-y-2 text-sm">
        <li>
          <a href="/pacientes/derechos-deberes" class="text-navy-700 hover:text-navy-600 transition-colors">
            Derechos y deberes del paciente →
          </a>
        </li>
        <li>
          <a href="/politica-de-privacidad" class="text-navy-700 hover:text-navy-600 transition-colors">
            Política de tratamiento de datos personales →
          </a>
        </li>
      </ul>
    </section>

  </div>
</BaseLayout>
