---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { SITE_CONFIG } from '@/lib/config';

interface Props {
  perfil: CollectionEntry<'perfiles'>['data'];
}

export async function getStaticPaths() {
  const perfiles = await getCollection('perfiles');
  return perfiles.map((perfil: CollectionEntry<'perfiles'>) => ({
    params: { slug: perfil.data.slug },
    props: { perfil: perfil.data },
  }));
}

const { perfil } = Astro.props;

const waUrl = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent(`Quiero solicitar el ${perfil.nombre}`)}`;
---

<BaseLayout title={perfil.nombre} description={perfil.descripcion}>
  <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6">

    <Breadcrumb items={[
      { label: 'Inicio', href: '/' },
      { label: 'Exámenes', href: '/examenes' },
      { label: 'Paquetes y perfiles', href: '/examenes/perfiles' },
      { label: perfil.nombre },
    ]} />

    <article>
      <header class="mt-6">
        <h1 class="text-2xl font-bold text-gray-900 sm:text-3xl">{perfil.nombre}</h1>
        <p class="mt-2 text-gray-600">{perfil.descripcion}</p>
      </header>

      <!-- Price + note -->
      <div class="mt-6 flex flex-wrap items-center gap-4">
        {perfil.precio && (
          <div class="inline-flex items-center gap-3 rounded-xl border border-blue-200 bg-blue-50 px-5 py-3">
            <span class="text-sm text-blue-600">Precio referencial</span>
            <span class="text-xl font-bold text-blue-700">
              ${perfil.precio.toLocaleString('es-CO')}
            </span>
          </div>
        )}
        <p class="text-sm italic text-gray-500">
          No es obligatorio tomar la totalidad de los exámenes del perfil.
        </p>
      </div>

      <!-- Exam list -->
      <section aria-labelledby="examenes-incluidos-heading" class="mt-8">
        <h2 id="examenes-incluidos-heading" class="text-xs font-medium uppercase tracking-wide text-gray-500">
          Exámenes incluidos ({perfil.examenesIncluidos.length})
        </h2>
        <ul role="list" class="mt-4 space-y-2">
          {perfil.examenesIncluidos.map((examen: { nombre: string; slug?: string }) => (
            <li class="flex items-center gap-3 rounded-lg bg-gray-50 px-4 py-3 text-sm text-gray-700">
              <span class="shrink-0 font-bold text-green-600">✓</span>
              {examen.slug ? (
                <a
                  href={`/examenes/${examen.slug}`}
                  class="flex items-center gap-1.5 hover:text-red-600 transition-colors duration-200"
                >
                  {examen.nombre}
                  <svg
                    class="h-3.5 w-3.5 shrink-0 text-gray-400"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round"
                      d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                  </svg>
                </a>
              ) : (
                <span>{examen.nombre}</span>
              )}
            </li>
          ))}
        </ul>
      </section>

      <!-- WhatsApp CTA -->
      <div class="mt-8">
        <a
          href={waUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg bg-green-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-green-700 active:scale-95 transition-all duration-200"
        >
          Solicitar por WhatsApp
        </a>
      </div>
    </article>

  </div>
</BaseLayout>
