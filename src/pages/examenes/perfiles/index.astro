---
/**
 * /examenes/perfiles — Listing page for exam profiles/panels.
 *
 * TODO (design-needed): Card layout with included exams list preview.
 * TODO (content-needed): Add pricing for all perfiles once confirmed.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const perfiles = await getCollection('perfiles');
---

<BaseLayout
  title="Perfiles de Exámenes"
  description="Baterías de exámenes recomendadas para etapas de vida, control médico y seguimiento. CIC Laboratorios."
>
  <div class="mx-auto max-w-4xl px-4 py-8 sm:px-6">

    <Breadcrumb items={[
      { label: 'Inicio', href: '/' },
      { label: 'Exámenes', href: '/examenes' },
      { label: 'Perfiles' },
    ]} />

    <header>
      <h1>Perfiles de exámenes</h1>
      <p class="mt-2">Baterías diseñadas para etapas de vida y seguimiento médico.</p>
    </header>

    <ul role="list" class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2">
      {perfiles.map((perfil: CollectionEntry<'perfiles'>) => (
        <li>
          <a href={`/examenes/perfiles/${perfil.data.slug}`}>
            <strong>{perfil.data.nombre}</strong>
          </a>
          <p class="mt-1">{perfil.data.descripcion}</p>
          {perfil.data.precio && (
            <p class="mt-1">Precio referencial: ${perfil.data.precio.toLocaleString('es-CO')}</p>
          )}
          <p class="mt-1">{perfil.data.examenesIncluidos.length} exámen(es) incluido(s)</p>
        </li>
      ))}
    </ul>

  </div>
</BaseLayout>
