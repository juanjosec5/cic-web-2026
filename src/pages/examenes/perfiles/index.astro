---
/**
 * /examenes/perfiles — Listing page for exam profiles/panels.
 *
 * TODO (design-needed): Card layout with included exams list preview.
 * TODO (content-needed): Add pricing for all perfiles once confirmed.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const perfiles = await getCollection('perfiles');
---

<BaseLayout
  title="Perfiles de Exámenes"
  description="Baterías de exámenes recomendadas para etapas de vida, control médico y seguimiento. CIC Laboratorios."
>
  <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6">

    <Breadcrumb items={[
      { label: 'Inicio', href: '/' },
      { label: 'Exámenes', href: '/examenes' },
      { label: 'Perfiles' },
    ]} />

    <header>
      <h1>Perfiles de exámenes</h1>
      <p class="mt-2">Baterías diseñadas para etapas de vida y seguimiento médico.</p>
    </header>

    <ul role="list" class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2">
      {perfiles.map((perfil: CollectionEntry<'perfiles'>) => (
        <li>
          <a href={`/examenes/perfiles/${perfil.data.slug}`}
             class="group block rounded-xl border border-gray-200 p-6 transition-all duration-200 hover:shadow-lg hover:-translate-y-1">
            <h2 class="font-semibold text-gray-900 transition-colors duration-200 group-hover:text-red-600">
              {perfil.data.nombre}
            </h2>
            <p class="mt-2 text-sm text-gray-600">{perfil.data.descripcion}</p>
            <div class="mt-4 flex items-center justify-between">
              <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-600">
                {perfil.data.examenesIncluidos.length} exámenes incluidos
              </span>
              {perfil.data.precio && (
                <span class="text-sm font-medium text-gray-700">
                  ${perfil.data.precio.toLocaleString('es-CO')}
                </span>
              )}
            </div>
          </a>
        </li>
      ))}
    </ul>

  </div>
</BaseLayout>
