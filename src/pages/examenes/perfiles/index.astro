---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const perfiles = await getCollection('perfiles');
const sorted = [...perfiles].sort((a, b) => (a.data.precio ?? 0) - (b.data.precio ?? 0));
---

<BaseLayout
  title="Paquetes y Perfiles de Exámenes"
  description="Baterías de exámenes para etapas de vida, control médico y seguimiento. CIC Laboratorios."
>
  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6">

    <Breadcrumb items={[
      { label: 'Inicio', href: '/' },
      { label: 'Exámenes', href: '/examenes' },
      { label: 'Paquetes y perfiles' },
    ]} />

    <header class="mt-6">
      <h1 class="text-2xl font-bold text-gray-900 sm:text-3xl">Paquetes y perfiles</h1>
      <p class="mt-2 text-gray-600 max-w-2xl">
        Baterías de exámenes diseñadas para etapas de vida, seguimiento médico y detección temprana.
        No es obligatorio tomar la totalidad de los exámenes de cada perfil.
      </p>
    </header>

    <ul role="list" class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {sorted.map((perfil: CollectionEntry<'perfiles'>) => (
        <li class="relative flex flex-col rounded-xl border border-gray-200 bg-white transition-all duration-200 hover:shadow-md hover:-translate-y-0.5">
          <!-- Price badge -->
          {perfil.data.precio && (
            <div class="absolute right-4 top-4">
              <span class="inline-block rounded-full bg-blue-50 px-3 py-1 text-sm font-semibold text-blue-700">
                ${perfil.data.precio.toLocaleString('es-CO')}
              </span>
            </div>
          )}

          <div class="flex flex-1 flex-col p-5 pr-28">
            <h2 class="text-base font-semibold text-gray-900 leading-snug">
              {perfil.data.nombre}
            </h2>
            <p class="mt-1.5 text-xs text-gray-500 leading-relaxed line-clamp-2">
              {perfil.data.descripcion}
            </p>

            <!-- Exam preview (first 3) -->
            <ul class="mt-3 space-y-1">
              {perfil.data.examenesIncluidos.slice(0, 3).map((examen: { nombre: string; slug?: string }) => (
                <li class="flex items-center gap-1.5 text-xs text-gray-600">
                  <span class="text-green-500 font-bold shrink-0">✓</span>
                  <span class="truncate">{examen.nombre}</span>
                </li>
              ))}
              {perfil.data.examenesIncluidos.length > 3 && (
                <li class="text-xs text-gray-400 pl-4">
                  +{perfil.data.examenesIncluidos.length - 3} más
                </li>
              )}
            </ul>
          </div>

          <!-- Footer -->
          <div class="flex items-center justify-between border-t border-gray-100 px-5 py-3">
            <span class="text-xs text-gray-400">
              {perfil.data.examenesIncluidos.length} exámenes
            </span>
            <a
              href={`/examenes/perfiles/${perfil.data.slug}`}
              class="text-xs font-semibold text-red-600 hover:text-red-700 transition-colors after:absolute after:inset-0"
            >
              Ver perfil →
            </a>
          </div>
        </li>
      ))}
    </ul>

  </div>
</BaseLayout>
