---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const perfiles = await getCollection('perfiles');
const sorted = [...perfiles].sort((a, b) => (a.data.precio ?? 0) - (b.data.precio ?? 0));

const CATEGORIA_MAP: Record<string, string> = {
  'lipidico':             'cardiovascular',
  'hipertension':         'cardiovascular',
  'renal':                'metabolico',
  'hepatico':             'metabolico',
  'diabetico':            'metabolico',
  'tiroideo':             'metabolico',
  'dengue-igm':           'infeccioso',
  'dengue-ns1':           'infeccioso',
  'enfermedades-sexuales':'infeccioso',
  'ninos':                'general',
  'deportivo':            'general',
  'pre-quirurgico':       'general',
  'prenatal':             'femenino',
  'mujer-gestante':       'femenino',
  'femenino':             'femenino',
  'general-mujeres':      'femenino',
  'prostatico':           'masculino',
  'general-hombres':      'masculino',
};

const FILTROS = [
  { value: 'todos',         label: 'Todos' },
  { value: 'cardiovascular',label: 'Cardiovascular' },
  { value: 'metabolico',    label: 'Metabólico' },
  { value: 'infeccioso',    label: 'Infeccioso' },
  { value: 'femenino',      label: 'Femenino' },
  { value: 'masculino',     label: 'Masculino' },
  { value: 'general',       label: 'General' },
];
---

<BaseLayout
  title="Paquetes y Perfiles de Exámenes"
  description="Baterías de exámenes para etapas de vida, control médico y seguimiento. CIC Laboratorios."
>
  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6">

    <Breadcrumb items={[
      { label: 'Inicio', href: '/' },
      { label: 'Exámenes', href: '/examenes' },
      { label: 'Paquetes y perfiles' },
    ]} />

    <header class="mt-6">
      <h1 class="text-2xl font-bold text-gray-900 sm:text-3xl">Paquetes y perfiles</h1>
      <p class="mt-2 text-gray-600 max-w-2xl">
        Baterías de exámenes diseñadas para etapas de vida, seguimiento médico y detección temprana.
        No es obligatorio tomar la totalidad de los exámenes de cada perfil.
      </p>
    </header>

    <!-- Filter pills -->
    <div class="mt-6 flex flex-wrap gap-2" role="group" aria-label="Filtrar por categoría">
      {FILTROS.map((f) => (
        <button
          type="button"
          data-filter={f.value}
          class:list={[
            'filter-pill rounded-full border px-4 py-1.5 text-sm font-medium transition-colors duration-150',
            f.value === 'todos'
              ? 'border-red-600 bg-red-600 text-white'
              : 'border-gray-300 bg-white text-gray-600 hover:border-gray-400 hover:text-gray-900',
          ]}
        >
          {f.label}
        </button>
      ))}
    </div>

    <!-- Cards -->
    <ul id="perfiles-grid" role="list" class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {sorted.map((perfil: CollectionEntry<'perfiles'>) => (
        <li
          class="relative flex flex-col rounded-xl border border-gray-200 bg-white transition-all duration-200 hover:shadow-md hover:-translate-y-0.5"
          data-categoria={CATEGORIA_MAP[perfil.data.slug] ?? 'general'}
        >
          <!-- Price badge -->
          {perfil.data.precio && (
            <div class="absolute right-4 top-4">
              <span class="inline-block rounded-full bg-blue-50 px-3 py-1 text-sm font-semibold text-blue-700">
                ${perfil.data.precio.toLocaleString('es-CO')} COP
              </span>
            </div>
          )}

          <div class="flex flex-1 flex-col p-5 pr-28">
            <h2 class="text-base font-semibold text-gray-900 leading-snug">
              {perfil.data.nombre}
            </h2>
            <p class="mt-1.5 text-xs text-gray-500 leading-relaxed line-clamp-2">
              {perfil.data.descripcion}
            </p>

            <!-- Exam preview (first 3) -->
            <ul class="mt-3 space-y-1">
              {perfil.data.examenesIncluidos.slice(0, 3).map((examen: { nombre: string; slug?: string }) => (
                <li class="flex items-center gap-1.5 text-xs text-gray-600">
                  <span class="text-green-500 font-bold shrink-0">✓</span>
                  <span class="truncate">{examen.nombre}</span>
                </li>
              ))}
              {perfil.data.examenesIncluidos.length > 3 && (
                <li class="text-xs text-gray-400 pl-4">
                  +{perfil.data.examenesIncluidos.length - 3} más
                </li>
              )}
            </ul>
          </div>

          <!-- Footer -->
          <div class="flex items-center justify-between border-t border-gray-100 px-5 py-3">
            <span class="text-xs text-gray-400">
              {perfil.data.examenesIncluidos.length} exámenes
            </span>
            <a
              href={`/examenes/perfiles/${perfil.data.slug}`}
              class="text-xs font-semibold text-red-600 hover:text-red-700 transition-colors after:absolute after:inset-0"
            >
              Ver perfil →
            </a>
          </div>
        </li>
      ))}
    </ul>

    <!-- Empty state -->
    <p id="perfiles-empty" class="hidden mt-12 text-center text-sm text-gray-400">
      No hay perfiles en esta categoría.
    </p>

  </div>
</BaseLayout>

<script>
  const pills = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
  const cards = document.querySelectorAll<HTMLLIElement>('#perfiles-grid > li');
  const empty = document.getElementById('perfiles-empty');

  function applyFilter(filter: string) {
    let visible = 0;
    cards.forEach((card) => {
      const match = filter === 'todos' || card.dataset.categoria === filter;
      card.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    empty?.classList.toggle('hidden', visible > 0);
  }

  pills.forEach((pill) => {
    pill.addEventListener('click', () => {
      pills.forEach((p) => {
        p.classList.remove('border-red-600', 'bg-red-600', 'text-white');
        p.classList.add('border-gray-300', 'bg-white', 'text-gray-600');
      });
      pill.classList.remove('border-gray-300', 'bg-white', 'text-gray-600');
      pill.classList.add('border-red-600', 'bg-red-600', 'text-white');
      applyFilter(pill.dataset.filter ?? 'todos');
    });
  });
</script>
