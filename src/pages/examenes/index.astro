---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { CATEGORIAS } from '@/lib/config';

const examenes = await getCollection(
  'examenes',
  ({ data }: CollectionEntry<'examenes'>) => data.activo
);
---

<BaseLayout
  title="Catálogo de Exámenes"
  description={`${examenes.length} exámenes clínicos disponibles en CIC Laboratorios. Resultados el mismo día.`}
>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6">

    <header>
      <h1>Catálogo de exámenes</h1>
      <p>{examenes.length} exámenes disponibles — resultados el mismo día</p>
    </header>

    <!-- TODO (blocking-for-v1.1): Replace with ExamSearch island once Pagefind is configured -->
    <div class="mt-8 rounded-xl border border-dashed border-gray-300 bg-gray-50 p-6 text-center">
      <p class="text-sm text-gray-500">Buscador por nombre — próximamente</p>
    </div>

    <section aria-labelledby="categorias-heading" class="mt-10">
      <h2 id="categorias-heading">Buscar por categoría</h2>
      <ul role="list" class="mt-6 flex flex-wrap gap-3">
        {CATEGORIAS.map((cat) => (
          <li>
            <a href={`/examenes/categoria/${cat.slug}`}
               class="inline-flex items-center rounded-full bg-gray-100 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-red-50 hover:text-red-700 transition-colors duration-200">
              {cat.label}
            </a>
          </li>
        ))}
      </ul>
    </section>

  </div>
</BaseLayout>
