---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { CATEGORIAS } from '@/lib/config';

const examenes = await getCollection(
  'examenes',
  ({ data }: CollectionEntry<'examenes'>) => data.activo
);
---

<BaseLayout
  title="Catálogo de Exámenes"
  description={`${examenes.length} exámenes clínicos disponibles en CIC Laboratorios. Resultados el mismo día.`}
>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6">

    <header>
      <h1>Catálogo de exámenes</h1>
      <p>{examenes.length} exámenes disponibles — resultados el mismo día</p>
    </header>

    <!-- TODO (blocking-for-v1.1): Replace with ExamSearch island once Pagefind is configured -->
    <p class="mt-6">
      <em>[ Buscador por nombre — pendiente integración Pagefind ]</em>
    </p>

    <section aria-labelledby="categorias-heading" class="mt-10">
      <h2 id="categorias-heading">Buscar por categoría</h2>
      <ul role="list" class="mt-4 grid grid-cols-2 gap-4 sm:grid-cols-3">
        {CATEGORIAS.map((cat) => (
          <li>
            <a href={`/examenes/categoria/${cat.slug}`}>{cat.label}</a>
          </li>
        ))}
      </ul>
    </section>

  </div>
</BaseLayout>
