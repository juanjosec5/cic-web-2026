---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ExamSearch from '@/components/islands/ExamSearch.vue';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { CATEGORIAS } from '@/lib/config';

const examenes = await getCollection(
  'examenes',
  ({ data }: CollectionEntry<'examenes'>) => data.activo
);

const examenesParaSearch = examenes.map((e: CollectionEntry<'examenes'>) => ({
  slug: e.data.slug,
  nombre: e.data.nombre,
  categoria: e.data.categoria,
  categoriaLabel: CATEGORIAS.find((c) => c.slug === e.data.categoria)?.label ?? e.data.categoria,
  nombresAlternativos: e.data.nombresAlternativos,
  requiereAyuno: e.data.requiereAyuno ?? false,
}));
---

<BaseLayout
  title="Catálogo de Exámenes"
  description={`${examenes.length} exámenes clínicos disponibles en CIC Laboratorios. Resultados el mismo día.`}
>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6">

    <header>
      <h1>Catálogo de exámenes</h1>
      <p class="mt-1 text-gray-600">{examenes.length} exámenes disponibles — resultados el mismo día</p>
    </header>

    <div class="mt-8">
      <ExamSearch exams={examenesParaSearch} client:load />
    </div>

    <section aria-labelledby="categorias-heading" class="mt-10">
      <h2 id="categorias-heading" class="text-sm font-medium text-gray-500">O busca por categoría</h2>
      <ul role="list" class="mt-4 flex flex-wrap gap-3">
        {CATEGORIAS.map((cat) => (
          <li>
            <a href={`/examenes/categoria/${cat.slug}`}
               class="inline-flex items-center rounded-full bg-gray-100 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-red-50 hover:text-red-700 transition-colors duration-200">
              {cat.label}
            </a>
          </li>
        ))}
      </ul>
    </section>

  </div>
</BaseLayout>
