---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import ExamenLayout from '@/layouts/ExamenLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { CATEGORIAS, SITE_CONFIG } from '@/lib/config';

interface Props {
  examen: CollectionEntry<'examenes'>['data'];
  sedesData: Array<{ slug: string; nombre: string }>;
  relacionadosData: Array<{ slug: string; nombre: string }>;
}

export async function getStaticPaths() {
  const [examenes, sedes] = await Promise.all([
    getCollection('examenes', ({ data }: CollectionEntry<'examenes'>) => data.activo),
    getCollection('sedes'),
  ]);

  const sedeMap = new Map(sedes.map((s: CollectionEntry<'sedes'>) => [s.data.slug, s.data.nombre]));
  const examenMap = new Map(examenes.map((e: CollectionEntry<'examenes'>) => [e.data.slug, e.data.nombre]));

  // All sedes sorted sede principal first — used as fallback when sedesDisponibles is empty
  const allSedesData = [...sedes]
    .sort(
      (a: CollectionEntry<'sedes'>, b: CollectionEntry<'sedes'>) =>
        (b.data.esSedePrincipal ? 1 : 0) - (a.data.esSedePrincipal ? 1 : 0)
    )
    .map((s: CollectionEntry<'sedes'>) => ({ slug: s.data.slug, nombre: s.data.nombre }));

  return examenes.map((examen: CollectionEntry<'examenes'>) => ({
    params: { slug: examen.data.slug },
    props: {
      examen: examen.data,
      sedesData:
        examen.data.sedesDisponibles.length > 0
          ? examen.data.sedesDisponibles.map((slug: string) => ({
              slug,
              nombre: sedeMap.get(slug) ?? slug,
            }))
          : allSedesData,
      relacionadosData: examen.data.examenesRelacionados.map((slug: string) => ({
        slug,
        nombre: examenMap.get(slug) ?? slug,
      })),
    },
  }));
}

const { examen, sedesData, relacionadosData } = Astro.props;

const categoriaLabel =
  CATEGORIAS.find((c) => c.slug === examen.categoria)?.label ?? examen.categoria;

const waCotizar = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent(`Quisiera cotizar el examen: ${examen.nombre}`)}`;
const waDomicilio = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent(`Quisiera solicitar toma a domicilio para: ${examen.nombre}`)}`;

const SEDES_PREVIEW = 3;
const displayedSedes = sedesData.slice(0, SEDES_PREVIEW);
const remainingCount = sedesData.length - SEDES_PREVIEW;
---

<ExamenLayout examen={examen}>
  <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6">

    <Breadcrumb items={[
      { label: 'Inicio', href: '/' },
      { label: 'Exámenes', href: '/examenes' },
      { label: categoriaLabel, href: `/examenes/categoria/${examen.categoria}` },
      { label: examen.nombre },
    ]} />

    <article>

      <!-- Header card -->
      <header class="mt-6 rounded-xl border border-gray-200 p-6">
        <p class="text-xs font-medium uppercase tracking-wide text-gray-500">
          Categoría · {categoriaLabel}
        </p>
        <h1 class="mt-2 text-2xl font-bold text-gray-900 sm:text-3xl">{examen.nombre}</h1>
        {examen.nombresAlternativos.length > 0 && (
          <p class="mt-1 text-sm text-gray-500">
            También conocido como: {examen.nombresAlternativos.join(', ')}
          </p>
        )}
        <div class="mt-6 flex flex-wrap gap-3">
          <a href={waCotizar} target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-2 rounded-lg bg-green-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-green-700 active:scale-95 transition-all duration-200">
            Cotizar por WhatsApp
          </a>
          <a href={waDomicilio} target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center rounded-lg border border-gray-300 bg-white px-5 py-2.5 text-sm font-semibold text-gray-700 hover:bg-gray-50 active:scale-95 transition-all duration-200">
            Solicitar domicilio
          </a>
          <a href="/sedes"
             class="inline-flex items-center rounded-lg border border-gray-300 bg-white px-5 py-2.5 text-sm font-semibold text-gray-700 hover:bg-gray-50 active:scale-95 transition-all duration-200">
            Ver sedes disponibles
          </a>
        </div>
      </header>

      <!-- 4-stat strip -->
      <dl class="mt-6 grid grid-cols-2 gap-px overflow-hidden rounded-xl border border-gray-200 bg-gray-200 sm:grid-cols-4">
        {examen.muestra && (
          <div class="bg-white p-4">
            <dt class="text-xs font-medium uppercase tracking-wide text-gray-500">Muestra</dt>
            <dd class="mt-1 font-semibold text-gray-900">{examen.muestra}</dd>
          </div>
        )}
        <div class="bg-white p-4">
          <dt class="text-xs font-medium uppercase tracking-wide text-gray-500">Ayuno</dt>
          <dd class="mt-1 font-semibold text-gray-900">
            {examen.requiereAyuno === true ? 'Requerido' : examen.requiereAyuno === false ? 'No requiere' : '—'}
          </dd>
        </div>
        {examen.oportunidadResultados && (
          <div class="bg-white p-4">
            <dt class="text-xs font-medium uppercase tracking-wide text-gray-500">Resultados</dt>
            <dd class="mt-1 font-semibold text-gray-900">{examen.oportunidadResultados}</dd>
          </div>
        )}
        <div class="bg-white p-4">
          <dt class="text-xs font-medium uppercase tracking-wide text-gray-500">Precio</dt>
          <dd class="mt-1 font-semibold text-gray-900">Cotizar</dd>
        </div>
      </dl>

      <!-- ¿Qué es? — always rendered -->
      <section aria-labelledby="que-es-heading" class="mt-6 rounded-xl border border-gray-200 p-6">
        <h2 id="que-es-heading" class="text-xs font-medium uppercase tracking-wide text-gray-500">
          ¿Qué es?
        </h2>
        {examen.descripcionQueEs ? (
          <p class="mt-3 text-gray-700">{examen.descripcionQueEs}</p>
        ) : (
          <p class="mt-3 text-sm italic text-gray-400">
            [ Descripción clínica del examen — próximamente ]
          </p>
        )}
      </section>

      <!-- ¿Para qué sirve? + Preparación — always rendered -->
      <div class="mt-6 grid grid-cols-1 gap-6 md:grid-cols-2">
        <section aria-labelledby="para-que-heading" class="rounded-xl border border-gray-200 p-6">
          <h3 id="para-que-heading" class="text-xs font-medium uppercase tracking-wide text-gray-500">
            ¿Para qué sirve?
          </h3>
          {examen.descripcionParaQueSirve ? (
            <p class="mt-3 text-gray-700">{examen.descripcionParaQueSirve}</p>
          ) : (
            <p class="mt-3 text-sm italic text-gray-400">[ Próximamente ]</p>
          )}
        </section>

        <section aria-labelledby="preparacion-heading" class="rounded-xl border border-gray-200 p-6">
          <h3 id="preparacion-heading" class="text-xs font-medium uppercase tracking-wide text-gray-500">
            Preparación
          </h3>
          {examen.preparacion ? (
            <div class="mt-3">
              {examen.requiereAyuno && (
                <p class="text-sm font-semibold text-amber-700">Requiere ayuno.</p>
              )}
              <p class="text-gray-700">{examen.preparacion}</p>
            </div>
          ) : (
            <p class="mt-3 text-sm italic text-gray-400">[ Próximamente ]</p>
          )}
        </section>
      </div>

      <!-- Sedes donde se realiza -->
      <section aria-labelledby="sedes-heading" class="mt-6 rounded-xl border border-gray-200 p-6">
        <h2 id="sedes-heading" class="text-xs font-medium uppercase tracking-wide text-gray-500">
          Toma de muestra disponible en
        </h2>
        <p class="mt-1 text-xs text-gray-400">
          El procesamiento se realiza en nuestra <a href="/sedes/buga" class="underline hover:text-gray-600 transition-colors duration-200">sede principal en Buga</a>.
        </p>
        <ul role="list" class="mt-4 flex flex-wrap gap-2">
          {displayedSedes.map(({ slug, nombre }) => (
            <li>
              <a href={`/sedes/${slug}`}
                 class="inline-flex items-center rounded-full bg-gray-100 px-3 py-1.5 text-sm font-medium text-gray-700 hover:bg-red-50 hover:text-red-700 transition-colors duration-200">
                {nombre} →
              </a>
            </li>
          ))}
          {remainingCount > 0 && (
            <li>
              <a href="/sedes"
                 class="inline-flex items-center rounded-full bg-gray-100 px-3 py-1.5 text-sm font-medium text-gray-500 hover:bg-red-50 hover:text-red-700 transition-colors duration-200">
                +{remainingCount} más
              </a>
            </li>
          )}
        </ul>
      </section>

      <!-- Exámenes relacionados -->
      {relacionadosData.length > 0 && (
        <section aria-labelledby="relacionados-heading" class="mt-6 rounded-xl border border-gray-200 p-6">
          <h2 id="relacionados-heading" class="text-xs font-medium uppercase tracking-wide text-gray-500">
            Exámenes relacionados
          </h2>
          <ul role="list" class="mt-4 space-y-2">
            {relacionadosData.map(({ slug, nombre }) => (
              <li>
                <a href={`/examenes/${slug}`}
                   class="block rounded-lg border border-gray-200 px-4 py-3 text-sm font-medium text-gray-900 hover:border-red-200 hover:text-red-700 transition-colors duration-200">
                  {nombre} →
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      <!-- WhatsApp CTA banner -->
      <section aria-labelledby="wa-cta-heading" class="mt-6 rounded-xl bg-gray-50 p-8 text-center">
        <h2 id="wa-cta-heading" class="text-lg font-semibold text-gray-900">
          ¿Tienes preguntas sobre este examen?
        </h2>
        <p class="mt-2 text-sm text-gray-600">
          Escríbenos por WhatsApp y te ayudamos con cotización, preparación y agendamiento.
        </p>
        <a
          href={waCotizar}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-6 inline-flex items-center gap-2 rounded-lg bg-green-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-green-700 active:scale-95 transition-all duration-200"
        >
          Abrir WhatsApp
        </a>
      </section>

      <!-- Medical disclaimer -->
      <p class="mt-8 border-t border-gray-200 pt-6 text-sm italic text-gray-400">
        <small>
          La información tiene fines orientativos. Consulta a tu médico para interpretación de resultados.
        </small>
      </p>

    </article>
  </div>
</ExamenLayout>
