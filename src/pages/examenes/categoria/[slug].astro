---
/**
 * /examenes/categoria/[slug] — Exámenes filtered by category.
 *
 * TODO (design-needed): Add category hero/description section.
 * TODO (content-needed): Add human-readable category descriptions.
 * TODO (blocking-for-v1): Add pagination for categories with many exams.
 */
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { CATEGORIAS } from '@/lib/config';

interface Props {
  categoria: CollectionEntry<'examenes'>['data']['categoria'];
  examenes: CollectionEntry<'examenes'>['data'][];
  label: string;
}

export async function getStaticPaths() {
  const examenes = await getCollection(
    'examenes',
    ({ data }: CollectionEntry<'examenes'>) => data.activo
  );

  const categorias = [
    ...new Set(examenes.map((e: CollectionEntry<'examenes'>) => e.data.categoria)),
  ];

  return categorias.map((categoria) => {
    const label =
      CATEGORIAS.find((c) => c.slug === categoria)?.label ?? categoria;
    return {
      params: { slug: categoria },
      props: {
        categoria,
        label,
        examenes: examenes
          .filter((e: CollectionEntry<'examenes'>) => e.data.categoria === categoria)
          .map((e: CollectionEntry<'examenes'>) => e.data),
      },
    };
  });
}

const { categoria, label, examenes } = Astro.props;
---

<BaseLayout
  title={`Exámenes de ${label}`}
  description={`Exámenes de ${label} disponibles en CIC Laboratorios. Resultados el mismo día.`}
>
  <div class="mx-auto max-w-4xl px-4 py-8 sm:px-6">

    <Breadcrumb items={[
      { label: 'Inicio', href: '/' },
      { label: 'Exámenes', href: '/examenes' },
      { label },
    ]} />

    <header>
      <h1>Exámenes de {label}</h1>
      <p class="mt-2">{examenes.length} exámen(es) en esta categoría.</p>
    </header>

    <ul role="list" class="mt-8 grid grid-cols-1 gap-3 sm:grid-cols-2">
      {examenes.map((ex) => (
        <li>
          <a href={`/examenes/${ex.slug}`}
             class="flex items-center justify-between rounded-lg border border-gray-200 px-4 py-3 text-sm font-medium text-gray-900 transition-colors duration-200 hover:border-red-200 hover:text-red-700">
            <span>{ex.nombre}</span>
            {ex.requiereAyuno && (
              <span class="ml-2 shrink-0 rounded-full bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-700">Ayuno</span>
            )}
          </a>
        </li>
      ))}
    </ul>

  </div>
</BaseLayout>
