---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Página no encontrada"
  description="La página que buscas no existe. Vuelve al inicio o busca un examen."
>
  <div class="flex flex-1 items-center justify-center px-4 py-24">
    <div class="text-center">
      <h1>Página no encontrada</h1>
      <p class="mt-4">Lo sentimos, no pudimos encontrar la página que buscas.</p>
      <nav aria-label="Sugerencias de navegación" class="mt-8">
        <ul role="list" class="flex flex-wrap justify-center gap-6">
          <li><a href="/">Inicio</a></li>
          <li><a href="/sedes">Sedes</a></li>
          <li><a href="/examenes">Exámenes</a></li>
        </ul>
      </nav>
    </div>
  </div>
</BaseLayout>
