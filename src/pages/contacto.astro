---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE_CONFIG } from '@/lib/config';

const { sedePrincipal, whatsapp } = SITE_CONFIG;
const waUrl = `https://wa.me/${whatsapp}?text=${encodeURIComponent('Hola, quisiera información de CIC Laboratorios.')}`;
---

<BaseLayout
  title="Contacto"
  description="Ponte en contacto con CIC Laboratorios. Encuentra teléfonos, dirección y WhatsApp de nuestra sede principal en Guadalajara de Buga."
>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6">

    <h1>Contáctenos</h1>

    <div class="mt-10 grid grid-cols-1 gap-10 md:grid-cols-2">

      <!-- Left: sede principal info + CTAs -->
      <section aria-labelledby="contacto-info-heading">
        <h2 id="contacto-info-heading">{sedePrincipal.nombre}</h2>
        <address class="mt-4 not-italic space-y-2">
          <p>{sedePrincipal.direccion}</p>
          <p>{sedePrincipal.ciudad}</p>
        </address>

        <div class="mt-6 flex flex-col gap-4">
          <a href={waUrl} target="_blank" rel="noopener noreferrer">
            WhatsApp: {sedePrincipal.whatsapp}
          </a>
          <a href={`tel:${sedePrincipal.telefono}`}>
            Llamar: {sedePrincipal.telefono}
          </a>
        </div>

        <p class="mt-6">
          {/* TODO (content-needed): Add form in v2 (Resend / Formspree) */}
          Para otras consultas también puedes escribirnos a{' '}
          <a href="mailto:info@ciclaboratorios.com">
            info@ciclaboratorios.com
          </a>
        </p>

        <p class="mt-4">
          <a href="/sedes">Ver todas las sedes →</a>
        </p>
      </section>

      <!-- Right: map placeholder -->
      <section aria-labelledby="mapa-contacto-heading">
        <h2 id="mapa-contacto-heading" class="sr-only">
          Ubicación de {sedePrincipal.nombre}
        </h2>
        {/* TODO (blocking-for-v1.1): Replace with real map embed */}
        <div
          class="aspect-video w-full"
          role="img"
          aria-label={`Mapa de ${sedePrincipal.nombre} — próximamente`}
        >
          <p>[ Mapa — próximamente ]</p>
        </div>
      </section>

    </div>
  </div>
</BaseLayout>
