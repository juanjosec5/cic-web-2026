---
/**
 * /servicios — Services listing page.
 *
 * TODO (design-needed): Icon cards for each service.
 * TODO (content-needed): Add service images/icons.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const servicios = await getCollection('servicios');
---

<BaseLayout
  title="Nuestros Servicios"
  description="Servicios de CIC Laboratorios: toma a domicilio, ginecología y VPH, jornadas empresariales y salud ocupacional."
>
  <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
    <Breadcrumb items={[{ label: 'Inicio', href: '/' }, { label: 'Servicios' }]} />

    <header>
      <h1>Nuestros servicios</h1>
    </header>

    <ul role="list" class="mt-8 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {servicios.map((servicio: CollectionEntry<'servicios'>) => (
        <li>
          <a href={`/servicios/${servicio.data.slug}`}
             class="group block rounded-xl border border-gray-200 p-6 transition-all duration-200 hover:shadow-lg hover:-translate-y-1">
            <h2 class="font-semibold transition-colors duration-200 group-hover:text-red-600">
              {servicio.data.nombre}
            </h2>
            <p class="mt-2 text-sm text-gray-600">{servicio.data.descripcion}</p>
            <span class="mt-4 inline-block text-sm font-medium text-red-600 transition-transform duration-200 group-hover:translate-x-1">
              Saber más →
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
