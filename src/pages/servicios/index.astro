---
/** /servicios — Services listing page. */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import HeroIcon from '@/components/HeroIcon.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { SERVICE_ICONS } from '@/lib/icons';

const servicios = await getCollection('servicios');
---

<BaseLayout
  title="Nuestros Servicios"
  description="Servicios de CIC Laboratorios: toma a domicilio, citología y VPH, jornadas empresariales y salud ocupacional."
>
  <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
    <Breadcrumb items={[{ label: 'Inicio', href: '/' }, { label: 'Servicios' }]} />

    <header>
      <h1>Nuestros servicios</h1>
    </header>

    <ul role="list" class="mt-8 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {servicios.map((servicio: CollectionEntry<'servicios'>) => (
        <li class="flex">
          <a href={`/servicios/${servicio.data.slug}`}
             class="group flex h-full w-full flex-col rounded-xl border border-gray-200 p-6 transition-all duration-200 hover:shadow-lg hover:-translate-y-1">
            {SERVICE_ICONS[servicio.data.slug] && (
              <HeroIcon path={SERVICE_ICONS[servicio.data.slug]} class="mb-3 h-8 w-8 text-red-600" />
            )}
            <h2 class="font-semibold transition-colors duration-200 group-hover:text-red-600">
              {servicio.data.nombre}
            </h2>
            <p class="mt-2 flex-1 text-sm text-gray-600">{servicio.data.descripcion}</p>
            <span class="mt-4 inline-flex items-center rounded-lg bg-red-600 px-4 py-2 text-sm font-semibold text-white transition-colors duration-200 group-hover:bg-red-700">
              Ver servicio
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
