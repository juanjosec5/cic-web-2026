---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const servicios = await getCollection('servicios');

const SERVICE_ICONS: Record<string, string> = {
  'domicilio':              'M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25',
  'ginecologia-vph':        'M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z',
  'jornadas-empresariales': 'M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z',
  'salud-ocupacional':      'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z',
};
---

<BaseLayout
  title="Nuestros Servicios"
  description="Servicios de CIC Laboratorios: toma a domicilio, citología y VPH, jornadas empresariales y salud ocupacional."
>
  <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
    <Breadcrumb items={[{ label: 'Inicio', href: '/' }, { label: 'Servicios' }]} />

    <header>
      <h1>Nuestros servicios</h1>
    </header>

    <ul role="list" class="mt-8 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {servicios.map((servicio: CollectionEntry<'servicios'>) => (
        <li class="flex">
          <a href={`/servicios/${servicio.data.slug}`}
             class="group flex h-full w-full flex-col rounded-xl border border-gray-200 p-6 transition-all duration-200 hover:shadow-lg hover:-translate-y-1">
            {SERVICE_ICONS[servicio.data.slug] && (
              <svg class="mb-3 h-8 w-8 text-red-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={SERVICE_ICONS[servicio.data.slug]} />
              </svg>
            )}
            <h2 class="font-semibold transition-colors duration-200 group-hover:text-red-600">
              {servicio.data.nombre}
            </h2>
            <p class="mt-2 flex-1 text-sm text-gray-600">{servicio.data.descripcion}</p>
            <span class="mt-4 inline-flex items-center rounded-lg bg-red-600 px-4 py-2 text-sm font-semibold text-white transition-colors duration-200 group-hover:bg-red-700">
              Ver servicio
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
