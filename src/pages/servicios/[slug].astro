---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { SITE_CONFIG } from '@/lib/config';

interface Props {
  servicio: CollectionEntry<'servicios'>['data'];
  sedesData: Array<{ slug: string; nombre: string }>;
}

export async function getStaticPaths() {
  const [servicios, sedes] = await Promise.all([
    getCollection('servicios'),
    getCollection('sedes'),
  ]);
  const sedeMap = new Map(sedes.map((s: CollectionEntry<'sedes'>) => [s.data.slug, s.data.nombre]));

  return servicios.map((servicio: CollectionEntry<'servicios'>) => ({
    params: { slug: servicio.data.slug },
    props: {
      servicio: servicio.data,
      sedesData: servicio.data.sedesDisponibles.map((slug: string) => ({
        slug,
        nombre: sedeMap.get(slug) ?? slug,
      })),
    },
  }));
}

const { servicio, sedesData } = Astro.props;

const ctaUrl =
  servicio.ctaTipo === 'whatsapp'
    ? `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent(`Quiero información sobre ${servicio.nombre}`)}`
    : servicio.ctaTipo === 'mailto'
    ? `mailto:info@ciclaboratorios.com?subject=${encodeURIComponent(servicio.nombre)}`
    : '/contacto';
---

<BaseLayout title={servicio.nombre} description={servicio.descripcion}>
  <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6">

    <Breadcrumb items={[
      { label: 'Inicio', href: '/' },
      { label: 'Servicios', href: '/servicios' },
      { label: servicio.nombre },
    ]} />

    <article class="mt-6">
      <h1>{servicio.nombre}</h1>
      <p class="mt-4">{servicio.descripcion}</p>

      <!-- Available sedes -->
      <section aria-labelledby="disponibilidad-heading" class="mt-10">
        <h2 id="disponibilidad-heading">Disponibilidad</h2>
        {sedesData.length === 0 || servicio.sedesDisponibles[0] === 'todas' ? (
          <p class="mt-4">Disponible en todas nuestras sedes.</p>
        ) : (
          <ul role="list" class="mt-4 flex flex-wrap gap-2">
            {sedesData.map(({ slug, nombre }) => (
              <li>
                <a href={`/sedes/${slug}`}
                   class="inline-flex items-center rounded-full bg-gray-100 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-red-50 hover:text-red-700 transition-colors duration-200">
                  {nombre}
                </a>
              </li>
            ))}
          </ul>
        )}
      </section>

      <!-- CTA -->
      <div class="mt-8">
        <a
          href={ctaUrl}
          class:list={[
            servicio.ctaTipo === 'whatsapp'
              ? "inline-flex items-center gap-2 rounded-lg bg-green-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-green-700 active:scale-95 transition-all duration-200"
              : "inline-flex items-center rounded-lg bg-red-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-red-700 active:scale-95 transition-all duration-200"
          ]}
          {...(servicio.ctaTipo === 'whatsapp'
            ? { target: '_blank', rel: 'noopener noreferrer' }
            : {})}
        >
          {servicio.ctaTipo === 'whatsapp'
            ? 'Solicitar por WhatsApp'
            : 'Solicitar información'}
        </a>
      </div>
    </article>

  </div>
</BaseLayout>
