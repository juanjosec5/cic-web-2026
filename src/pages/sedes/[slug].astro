---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import SedeLayout from '@/layouts/SedeLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { SITE_CONFIG } from '@/lib/config';

interface Props {
  sede: CollectionEntry<'sedes'>['data'];
  otrosSedes: Array<CollectionEntry<'sedes'>['data']>;
}

export async function getStaticPaths() {
  const sedes = await getCollection('sedes');
  return sedes.map((sede: CollectionEntry<'sedes'>) => ({
    params: { slug: sede.data.slug },
    props: {
      sede: sede.data,
      otrosSedes: sedes
        .filter((s: CollectionEntry<'sedes'>) => s.data.slug !== sede.data.slug)
        .slice(0, 3)
        .map((s: CollectionEntry<'sedes'>) => s.data),
    },
  }));
}

const { sede, otrosSedes } = Astro.props;

const waUrl = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent(`Hola, quisiera información sobre la sede ${sede.nombre}.`)}`;
const mapsUrl = sede.lat && sede.lng
  ? `https://www.google.com/maps/dir/?api=1&destination=${sede.lat},${sede.lng}`
  : `https://www.google.com/maps/search/${encodeURIComponent(`${sede.nombre} ${sede.direccion} ${sede.ciudad}`)}`;

const SERVICIO_LABELS: Record<string, string> = {
  'toma-muestras': 'Toma de muestras',
  'domicilio': 'Servicio a domicilio',
  'ginecologia-vph': 'Ginecología y VPH',
  'jornadas-empresariales': 'Jornadas empresariales',
  'salud-ocupacional': 'Salud ocupacional',
  'validacion-qr': 'Validación QR',
};
---

<SedeLayout sede={sede}>
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6">

    <Breadcrumb items={[
      { label: 'Inicio', href: '/' },
      { label: 'Sedes', href: '/sedes' },
      { label: sede.nombre },
    ]} />

    <!-- H1 + subheading -->
    <header class="mt-6">
      <h1>{sede.nombre}</h1>
      <p>{sede.direccion}, {sede.ciudad} · Sin cita previa</p>
    </header>

    <!-- CTA group -->
    <div class="mt-6 flex flex-wrap gap-3">
      <a href={waUrl} target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-2 rounded-lg bg-green-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-green-700 active:scale-95 transition-all duration-200">
        WhatsApp
      </a>
      <a href={`tel:${sede.telefono}`}
         class="inline-flex items-center rounded-lg border border-gray-300 bg-white px-5 py-2.5 text-sm font-semibold text-gray-700 hover:bg-gray-50 active:scale-95 transition-all duration-200">
        Llamar ({sede.telefono})
      </a>
      <a href={mapsUrl} target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center rounded-lg border border-gray-300 bg-white px-5 py-2.5 text-sm font-semibold text-gray-700 hover:bg-gray-50 active:scale-95 transition-all duration-200">
        Cómo llegar
      </a>
    </div>

    <!-- 2-col info strip -->
    <div class="mt-10 grid grid-cols-1 gap-8 md:grid-cols-2">

      <!-- Hours block -->
      <section aria-labelledby="horario-heading">
        <h2 id="horario-heading">Horario de atención</h2>
        <table class="mt-4 w-full text-sm">
          <caption class="sr-only">Horario de atención de {sede.nombre}</caption>
          <tbody>
            {Object.entries(sede.horario).map(([dia, horas]) => (
              horas ? (
                <tr class="even:bg-gray-50">
                  <th scope="row" class="py-2 pr-4 capitalize text-left font-medium text-gray-700">{dia}</th>
                  <td class="py-2 text-gray-600">{horas}</td>
                </tr>
              ) : null
            ))}
          </tbody>
        </table>
      </section>

      <!-- Contact block -->
      <section aria-labelledby="contacto-heading">
        <h2 id="contacto-heading">Contacto</h2>
        <address class="mt-4 not-italic space-y-2">
          <p>{sede.direccion}, {sede.ciudad}</p>
          <p>
            Tel: <a href={`tel:${sede.telefono}`}>{sede.telefono}</a>
          </p>
          <p>
            WhatsApp: <a href={waUrl} target="_blank" rel="noopener noreferrer">{sede.whatsapp}</a>
          </p>
          {sede.email && (
            <p>
              Email: <a href={`mailto:${sede.email}`}>{sede.email}</a>
            </p>
          )}
        </address>
      </section>
    </div>

    <!-- Map placeholder -->
    <section aria-labelledby="mapa-heading" class="mt-10">
      <h2 id="mapa-heading">Cómo llegar</h2>
      <!-- TODO (blocking-for-v1.1): Replace with real map embed (lat/lng available when populated) -->
      <div class="mt-4 aspect-video w-full rounded-xl bg-gray-100 flex items-center justify-center text-gray-400 text-sm"
           role="img" aria-label={`Mapa de ${sede.nombre} — próximamente`}>
        Mapa próximamente
      </div>
      <a href={mapsUrl} target="_blank" rel="noopener noreferrer"
         class="mt-2 inline-block text-sm font-medium text-gray-700 hover:text-red-600 transition-colors duration-200">
        Abrir en Google Maps →
      </a>
    </section>

    <!-- Services grid -->
    <section aria-labelledby="servicios-sede-heading" class="mt-10">
      <h2 id="servicios-sede-heading">Servicios disponibles</h2>
      <ul role="list" class="mt-4 flex flex-wrap gap-2">
        {sede.servicios.map((s: string) => (
          <li>
            <a href={`/servicios/${s}`}
               class="inline-flex items-center rounded-full bg-gray-100 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-red-50 hover:text-red-700 transition-colors duration-200">
              {SERVICIO_LABELS[s] ?? s}
            </a>
          </li>
        ))}
      </ul>

      {sede.domicilioGratisDesde !== undefined && (
        <p class="mt-4">
          Domicilio gratuito en pedidos desde $
          {sede.domicilioGratisDesde.toLocaleString('es-CO')}
        </p>
      )}
    </section>

    <!-- Gallery — only if fotos exist -->
    {sede.fotos.length > 0 && (
      <section aria-labelledby="galeria-heading" class="mt-10">
        <h2 id="galeria-heading">Galería</h2>
        <ul role="list" class="mt-4 grid grid-cols-2 gap-4 md:grid-cols-4">
          {sede.fotos.map((foto: string) => (
            <li>
              <img src={foto} alt={`Foto de ${sede.nombre}`} class="w-full" />
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- Convenios — only if exist -->
    {sede.convenios.length > 0 && (
      <section aria-labelledby="convenios-heading" class="mt-10">
        <h2 id="convenios-heading">Convenios</h2>
        <ul role="list" class="mt-4 flex flex-wrap gap-2">
          {sede.convenios.map((convenio: string) => (
            <li>{convenio}</li>
          ))}
        </ul>
      </section>
    )}

    <!-- Nearby sedes -->
    <section aria-labelledby="otras-sedes-heading" class="mt-10">
      <h2 id="otras-sedes-heading">Otras sedes</h2>
      <ul role="list" class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-3">
        {otrosSedes.map((otra) => (
          <li class="rounded-xl border border-gray-200 p-4 transition-all duration-200 hover:shadow-md hover:-translate-y-0.5">
            <a href={`/sedes/${otra.slug}`} class="font-semibold text-gray-900 hover:text-red-600 transition-colors duration-200">
              {otra.nombre}
            </a>
            <p class="mt-1 text-sm text-gray-500">{otra.ciudad}</p>
          </li>
        ))}
      </ul>
      <a href="/sedes" class="mt-4 inline-block text-sm font-medium text-gray-700 hover:text-red-600 transition-colors duration-200">
        Ver todas las sedes →
      </a>
    </section>

  </div>
</SedeLayout>
