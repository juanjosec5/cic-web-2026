---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import SedeMap from '@/components/islands/SedeMap.vue';
import { client } from '@/sanity/client';
import { ALL_SEDES_QUERY } from '@/sanity/queries';
import type { Sede } from '@/sanity/types';

const sedes: Sede[] = await client.fetch(ALL_SEDES_QUERY);
const sedesOrdenadas = [...sedes].sort((a, b) =>
  a.esSedePrincipal ? -1 : b.esSedePrincipal ? 1 : 0
);

const sedesParaMapa = sedesOrdenadas
  .filter((s: Sede) => s.lat != null && s.lng != null)
  .map((s: Sede) => ({
    slug: s.slug,
    nombre: s.nombre,
    ciudad: s.ciudad,
    direccion: s.direccion,
    telefono: s.telefono,
    whatsapp: s.whatsapp,
    lat: s.lat as number,
    lng: s.lng as number,
    esSedePrincipal: s.esSedePrincipal ?? false,
  }));

// Geographic zones for mobile accordion (latitude thresholds)
const NORTE_LAT = 4.3
const SUR_LAT   = 3.8

const zonas = {
  norte:  sedesOrdenadas.filter(s => (s.lat ?? 0) >= NORTE_LAT),
  centro: sedesOrdenadas.filter(s => (s.lat ?? 0) >= SUR_LAT && (s.lat ?? 0) < NORTE_LAT),
  sur:    sedesOrdenadas.filter(s => (s.lat ?? 0) < SUR_LAT),
}
---

<BaseLayout
  title="Nuestras Sedes"
  description={`Encuentra la sede de CIC Laboratorios más cercana a ti. ${sedes.length} sedes en el Valle del Cauca.`}
>
  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6">

    <Breadcrumb items={[{ label: 'Inicio', href: '/' }, { label: 'Sedes' }]} />

    <header>
      <h1>Nuestras sedes</h1>
      <p>Atendemos en {sedes.length} sedes en el Valle del Cauca — sin cita previa.</p>
    </header>

    <!-- Desktop: map + sidebar list (md+) -->
    <div class="hidden md:block mt-10">
      <SedeMap sedes={sedesParaMapa} showSidebar={true} client:visible />
      <div class="mt-3 flex flex-wrap items-center gap-x-5 gap-y-1 text-xs text-gray-400">
        <span class="flex items-center gap-1.5">
          <span class="inline-block h-2.5 w-2.5 rounded-full bg-blue-600"></span>
          Sede
        </span>
        <span class="flex items-center gap-1.5">
          <span class="inline-block h-2.5 w-2.5 rounded-full bg-emerald-600"></span>
          Sede principal
        </span>
        <span>· Pasa el cursor sobre un punto o nombre para resaltarlo</span>
      </div>
    </div>

    <!-- Mobile: accordion by geographic zone (below md) -->
    <div class="md:hidden mt-8 space-y-2">
      {[
        { label: 'Norte del Valle', sedes: zonas.norte },
        { label: 'Centro del Valle', sedes: zonas.centro },
        { label: 'Sur del Valle', sedes: zonas.sur },
      ].filter(z => z.sedes.length > 0).map(zona => (
        <details class="group rounded-xl border border-gray-200 overflow-hidden" open>
          <summary class="flex cursor-pointer items-center justify-between px-4 py-3 text-sm font-semibold text-gray-800 select-none list-none">
            <span>{zona.label}</span>
            <span class="flex items-center gap-2 text-gray-400">
              <span class="text-xs font-normal">{zona.sedes.length} sede{zona.sedes.length !== 1 ? 's' : ''}</span>
              <svg class="h-4 w-4 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </span>
          </summary>
          <ul role="list" class="border-t border-gray-100">
            {zona.sedes.map((sede: Sede) => (
              <li class="border-b border-gray-50 last:border-0">
                <a
                  href={`/sedes/${sede.slug}`}
                  class="flex items-start justify-between gap-3 px-4 py-3 text-sm transition-colors duration-150 hover:bg-red-50"
                >
                  <div>
                    <p class="font-medium text-gray-900">
                      {sede.ciudad}
                      {sede.esSedePrincipal && (
                        <span class="ml-2 inline-flex items-center rounded-full bg-green-100 px-1.5 py-0.5 text-[10px] font-medium text-green-700">Principal</span>
                      )}
                    </p>
                    <p class="mt-0.5 text-xs text-gray-400">{sede.direccion}</p>
                  </div>
                  <span class="mt-0.5 text-gray-300 text-xs shrink-0">→</span>
                </a>
              </li>
            ))}
          </ul>
        </details>
      ))}
    </div>

    <!-- Card grid (always visible) -->
    <section aria-labelledby="lista-sedes-heading" class="mt-12">
      <h2 id="lista-sedes-heading" class="sr-only">Lista de sedes</h2>
      <ul role="list" class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {sedesOrdenadas.map((sede: Sede) => (
          <li class="flex">
            <article class="flex h-full w-full flex-col rounded-xl border border-gray-200 p-6 transition-all duration-200 hover:shadow-lg hover:-translate-y-1">
              <header class="flex items-start justify-between gap-3">
                <h2 class="text-base font-semibold text-gray-900">
                  <a href={`/sedes/${sede.slug}`} class="hover:text-red-600 transition-colors duration-200">
                    {sede.nombre}
                  </a>
                </h2>
                {sede.esSedePrincipal && (
                  <span class="shrink-0 inline-flex items-center rounded-full bg-green-100 px-2 py-0.5 text-xs font-medium text-green-700">
                    Sede principal
                  </span>
                )}
              </header>
              <address class="mt-2 flex-1 text-sm text-gray-500 not-italic space-y-0.5">
                <p>{sede.direccion}</p>
                <p>{sede.ciudad}</p>
                <p>
                  <a href={`tel:${sede.telefono}`} class="hover:text-red-600 transition-colors duration-200">{sede.telefono}</a>
                </p>
              </address>
              <a href={`/sedes/${sede.slug}`} class="mt-4 inline-block text-sm font-medium text-red-600 hover:text-red-700 transition-colors duration-200">
                Ver detalles →
              </a>
            </article>
          </li>
        ))}
      </ul>
    </section>

  </div>
</BaseLayout>
