---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const sedes = await getCollection('sedes');
const sedesOrdenadas = [...sedes].sort((a, b) =>
  a.data.esSedePrincipal ? -1 : b.data.esSedePrincipal ? 1 : 0
);
---

<BaseLayout
  title="Nuestras Sedes"
  description={`Encuentra la sede de CIC Laboratorios más cercana a ti. ${sedes.length} sedes en el Valle del Cauca.`}
>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6">

    <header>
      <h1>Nuestras sedes</h1>
      <p>Atendemos en {sedes.length} sedes en el Valle del Cauca — sin cita previa.</p>
    </header>

    <!-- TODO (blocking-for-v1.1): Replace with interactive multi-sede map -->
    <div
      class="mt-8 aspect-video w-full"
      role="img"
      aria-label="Mapa interactivo de sedes — próximamente"
    >
      <p>[ Mapa interactivo de sedes — próximamente ]</p>
    </div>

    <section aria-labelledby="lista-sedes-heading" class="mt-12">
      <h2 id="lista-sedes-heading" class="sr-only">Lista de sedes</h2>
      <ul role="list" class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {sedesOrdenadas.map((sede: CollectionEntry<'sedes'>) => (
          <li>
            <article>
              <header>
                <h2>
                  <a href={`/sedes/${sede.data.slug}`}>{sede.data.nombre}</a>
                </h2>
                {sede.data.esSedePrincipal && (
                  <p>Sede principal</p>
                )}
              </header>
              <address class="mt-2 not-italic">
                <p>{sede.data.direccion}</p>
                <p>{sede.data.ciudad}</p>
                <p>
                  <a href={`tel:${sede.data.telefono}`}>{sede.data.telefono}</a>
                </p>
              </address>
              <a href={`/sedes/${sede.data.slug}`} class="mt-4 inline-block">
                Ver detalles →
              </a>
            </article>
          </li>
        ))}
      </ul>
    </section>

  </div>
</BaseLayout>
