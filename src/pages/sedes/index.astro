---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import SedeMapD3 from '@/components/islands/SedeMapD3.vue';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const sedes = await getCollection('sedes');
const sedesOrdenadas = [...sedes].sort((a, b) =>
  a.data.esSedePrincipal ? -1 : b.data.esSedePrincipal ? 1 : 0
);

const sedesParaMapa = sedesOrdenadas
  .filter((s: CollectionEntry<'sedes'>) => s.data.lat !== undefined && s.data.lng !== undefined)
  .map((s: CollectionEntry<'sedes'>) => ({
    slug: s.data.slug,
    nombre: s.data.nombre,
    ciudad: s.data.ciudad,
    direccion: s.data.direccion,
    telefono: s.data.telefono,
    whatsapp: s.data.whatsapp,
    lat: s.data.lat!,
    lng: s.data.lng!,
    esSedePrincipal: s.data.esSedePrincipal ?? false,
  }));
---

<BaseLayout
  title="Nuestras Sedes"
  description={`Encuentra la sede de CIC Laboratorios más cercana a ti. ${sedes.length} sedes en el Valle del Cauca.`}
>
  <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6">

    <Breadcrumb items={[{ label: 'Inicio', href: '/' }, { label: 'Sedes' }]} />

    <header>
      <h1>Nuestras sedes</h1>
      <p>Atendemos en {sedes.length} sedes en el Valle del Cauca — sin cita previa.</p>
    </header>

    <!-- Map: hidden on mobile (dots overlap at small sizes), visible sm+ -->
    <div class="hidden sm:block mt-10 mx-auto max-w-lg">

      <p class="mb-2 text-center text-sm font-medium text-gray-500">
        {sedesParaMapa.length} sedes en Valle del Cauca
      </p>

      <SedeMapD3 sedes={sedesParaMapa} client:visible />

      <div class="mt-3 flex flex-wrap items-center justify-center gap-x-5 gap-y-1 text-xs text-gray-500">
        <span class="flex items-center gap-1.5">
          <span class="inline-block h-2.5 w-2.5 rounded-full bg-blue-600"></span>
          Sede
        </span>
        <span class="flex items-center gap-1.5">
          <span class="inline-block h-2.5 w-2.5 rounded-full bg-emerald-600"></span>
          Sede principal
        </span>
        <span class="text-gray-400">· Pasa el cursor sobre un punto para ver detalles</span>
      </div>
    </div>

    <section aria-labelledby="lista-sedes-heading" class="mt-12">
      <h2 id="lista-sedes-heading" class="sr-only">Lista de sedes</h2>
      <ul role="list" class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {sedesOrdenadas.map((sede: CollectionEntry<'sedes'>) => (
          <li>
            <article class="rounded-xl border border-gray-200 p-6 transition-all duration-200 hover:shadow-lg hover:-translate-y-1">
              <header class="flex items-start justify-between gap-3">
                <h2 class="text-base font-semibold text-gray-900">
                  <a href={`/sedes/${sede.data.slug}`} class="hover:text-red-600 transition-colors duration-200">
                    {sede.data.nombre}
                  </a>
                </h2>
                {sede.data.esSedePrincipal && (
                  <span class="shrink-0 inline-flex items-center rounded-full bg-green-100 px-2 py-0.5 text-xs font-medium text-green-700">
                    Sede principal
                  </span>
                )}
              </header>
              <address class="mt-2 text-sm text-gray-500 not-italic space-y-0.5">
                <p>{sede.data.direccion}</p>
                <p>{sede.data.ciudad}</p>
                <p>
                  <a href={`tel:${sede.data.telefono}`} class="hover:text-red-600 transition-colors duration-200">{sede.data.telefono}</a>
                </p>
              </address>
              <a href={`/sedes/${sede.data.slug}`} class="mt-4 inline-block text-sm font-medium text-red-600 hover:text-red-700 transition-colors duration-200">
                Ver detalles →
              </a>
            </article>
          </li>
        ))}
      </ul>
    </section>

  </div>
</BaseLayout>
