---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroIcon from '@/components/HeroIcon.astro';
import SedeMap from '@/components/islands/SedeMap.vue';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { SITE_CONFIG, CATEGORIAS } from '@/lib/config';
import { SERVICE_ICONS } from '@/lib/icons';
import { buildOrganizationJsonLd } from '@/lib/seo';
import { client } from '@/sanity/client';
import { ALL_SEDES_QUERY, PROMO_MES_QUERY, PAGINA_INICIO_QUERY } from '@/sanity/queries';
import type { Sede, PromoMes, PaginaInicio } from '@/sanity/types';

const [sedes, promo, paginaInicio] = await Promise.all([
  client.fetch<Sede[]>(ALL_SEDES_QUERY),
  client.fetch<PromoMes | null>(PROMO_MES_QUERY),
  client.fetch<PaginaInicio | null>(PAGINA_INICIO_QUERY),
]);
const examenes = await getCollection('examenes', ({ data }: CollectionEntry<'examenes'>) => data.activo);
const servicios = await getCollection('servicios');
const aliados = await getCollection('aliados');

const waHero = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent('¡Hola! Quisiera información sobre los servicios de CIC Laboratorios.')}`;

const PILAR_SVGS = [
  'M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z',
  'M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5',
  'M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15M14.25 3.104c.251.023.501.05.75.082M19.8 15a2.25 2.25 0 0 1 .244 1.028l-.001.002a2.25 2.25 0 0 1-2.244 2.22H6.2a2.25 2.25 0 0 1-2.244-2.22l-.001-.002A2.25 2.25 0 0 1 4.2 15m15.6 0-3.675-1.845a2.25 2.25 0 0 0-2.25 0L9.75 15',
  'm2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25',
] as const;

const PILAR_LINKS: (string | null)[] = [null, null, '/examenes', '/servicios/domicilio'];

const DEFAULT_PILARES = [
  { titulo: 'Mismo día', descripcion: 'Resultados disponibles el mismo día de la toma.' },
  { titulo: 'Sin cita previa', descripcion: `Atención inmediata en las ${sedes.length} sedes.` },
  { titulo: `+${examenes.length} pruebas`, descripcion: 'El portafolio más completo de la región.' },
  { titulo: 'Servicio a domicilio', descripcion: 'Toma de muestras en tu hogar o empresa.' },
];

const DEFAULT_AUDIENCIAS = [
  {
    titulo: 'Soy paciente',
    descripcion: 'Resultados rápidos, sin cita, con atención humanizada.',
    links: [
      { label: 'Ver exámenes', url: '/examenes' },
      { label: 'Preparación de exámenes', url: '/pacientes/preparacion' },
    ],
  },
  {
    titulo: 'Soy empresa',
    descripcion: 'Salud ocupacional, jornadas empresariales y convenios.',
    links: [{ label: 'Servicios para empresas', url: '/empresas' }],
  },
  {
    titulo: 'Soy laboratorio / IPS',
    descripcion: 'Referencia de muestras y alianzas estratégicas.',
    links: [{ label: 'Alianzas con laboratorios', url: '/laboratorios' }],
  },
];

const DEFAULT_CALIDAD: NonNullable<PaginaInicio['calidad']> = [
  { titulo: 'Equipos de última generación', descripcion: 'Tecnología de punta para resultados precisos y confiables.' },
  { titulo: 'Política de seguridad del paciente', descripcion: 'Protocolos rigurosos que garantizan la seguridad en cada etapa.', linkLabel: 'Ver certificaciones', linkUrl: '/nosotros#calidad' },
  { titulo: 'Validación QR', descripcion: 'Verifica la autenticidad de tus resultados con el código QR único incluido en cada informe.' },
];

const pilares = paginaInicio?.pilares ?? DEFAULT_PILARES;
const audiencias = paginaInicio?.audiencias ?? DEFAULT_AUDIENCIAS;
const calidad = paginaInicio?.calidad ?? DEFAULT_CALIDAD;
const testimonios = paginaInicio?.testimonios ?? [];

const AUDIENCE_ICONS: Record<string, string> = {
  'Soy paciente':          'M17.982 18.725A7.488 7.488 0 0012 15.75a7.488 7.488 0 00-5.982 2.975m11.963 0a9 9 0 10-11.963 0m11.963 0A8.966 8.966 0 0112 21a8.966 8.966 0 01-5.982-2.275M15 9.75a3 3 0 11-6 0 3 3 0 016 0z',
  'Soy empresa':           'M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21',
  'Soy laboratorio / IPS': 'M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15M14.25 3.104c.251.023.501.05.75.082M19.8 15a2.25 2.25 0 0 1 .244 1.028l-.001.002a2.25 2.25 0 0 1-2.244 2.22H6.2a2.25 2.25 0 0 1-2.244-2.22l-.001-.002A2.25 2.25 0 0 1 4.2 15m15.6 0-3.675-1.845a2.25 2.25 0 0 0-2.25 0L9.75 15M8.25 2.25h7.5',
};

const sedesOrdenadas = [...sedes].sort((a, b) =>
  a.esSedePrincipal ? -1 : b.esSedePrincipal ? 1 : 0
);

const NORTE_LAT = 4.3;
const SUR_LAT   = 3.8;
const MOBILE_CAT_LIMIT = 12;
const zonas = {
  norte:  sedesOrdenadas.filter(s => (s.lat ?? 0) >= NORTE_LAT),
  centro: sedesOrdenadas.filter(s => (s.lat ?? 0) >= SUR_LAT && (s.lat ?? 0) < NORTE_LAT),
  sur:    sedesOrdenadas.filter(s => (s.lat ?? 0) < SUR_LAT),
};

const sedesParaMapa = sedes
  .filter((s: Sede) => s.lat != null && s.lng != null)
  .map((s: Sede) => ({
    slug: s.slug,
    nombre: s.nombre,
    ciudad: s.ciudad,
    direccion: s.direccion,
    telefono: s.telefono,
    whatsapp: s.whatsapp,
    lat: s.lat as number,
    lng: s.lng as number,
    esSedePrincipal: s.esSedePrincipal ?? false,
  }));
---

<BaseLayout
  title="Laboratorio Clínico en el Valle del Cauca"
  description={`CIC Laboratorios — ${examenes.length} exámenes clínicos con resultados el mismo día. ${sedes.length} sedes en el Valle del Cauca. Servicio a domicilio disponible.`}
  jsonLd={buildOrganizationJsonLd()}
>

  <!-- 1. MONTHLY PROMOTION BANNER (alert strip above hero) -->
  {promo && (
    <section aria-labelledby="promo-heading" class="py-6">
      <div class="mx-auto max-w-5xl px-4 sm:px-6">
        {promo.modo === 'imagen' && promo.imagenCompletaUrl ? (
          <a href={promo.ctaUrl ?? '#'} target="_blank" rel="noopener noreferrer">
            <img
              src={`${promo.imagenCompletaUrl}?w=1200&auto=format&q=85`}
              srcset={[
                `${promo.imagenCompletaUrl}?w=640&auto=format&q=85 640w`,
                `${promo.imagenCompletaUrl}?w=1024&auto=format&q=85 1024w`,
                `${promo.imagenCompletaUrl}?w=1600&auto=format&q=85 1600w`,
              ].join(', ')}
              sizes="(max-width: 640px) 640px, (max-width: 1024px) 1024px, 1600px"
              alt={promo.titulo ?? 'Promoción del mes'}
              class="w-full rounded-2xl object-cover"
              loading="eager"
              decoding="async"
              width="1600"
              height="600"
            />
          </a>
        ) : (
          <div
            class="flex flex-col gap-4 rounded-2xl px-8 py-7 sm:flex-row sm:items-center sm:justify-between"
            style={`background-color: ${promo.colorFondo ?? '#dc2626'};${promo.imagenFondoUrl ? ` background-image: url("${promo.imagenFondoUrl.replace(/"/g, '%22')}"); background-size: cover; background-position: center;` : ''}`}
          >
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-red-200">Promoción del mes</p>
              <h2 id="promo-heading" class="mt-1 text-xl text-white">{promo.titulo}</h2>
              {promo.descripcion && <p class="mt-1 text-sm text-red-100">{promo.descripcion}</p>}
            </div>
            <a
              href={promo.ctaUrl ?? '#'}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex w-full shrink-0 items-center justify-center rounded-lg bg-white px-6 py-3 text-sm font-semibold text-red-600 shadow-sm hover:bg-red-50 active:scale-95 transition-all duration-200 sm:w-auto"
            >
              {promo.ctaTexto ?? 'Consultar promoción'}
            </a>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- 2. HERO -->
  <section aria-labelledby="hero-heading" class="hero-bg py-20 md:py-32">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 text-center">
      <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-navy-700">Laboratorio clínico · Valle del Cauca</p>
      <h1 id="hero-heading" class="text-4xl md:text-5xl lg:text-6xl">
        {paginaInicio?.heroTitulo ?? 'Resultados que transforman vidas'}
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600">
        {paginaInicio?.heroSubtitulo ?? 'Más de'} {examenes.length} exámenes clínicos — resultados el mismo día, sin cita previa, en {sedes.length} sedes del Valle del Cauca.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-3">
        <a href={paginaInicio?.heroCta1Url ?? '/sedes'}
           class="inline-flex items-center rounded-lg bg-navy-800 px-7 py-3.5 text-sm font-semibold text-white shadow-sm hover:bg-navy-700 active:scale-95 transition-all duration-200">
          {paginaInicio?.heroCta1Label ?? 'Encontrar sede'}
        </a>
        <a href={paginaInicio?.heroCta2Url ?? '/examenes'}
           class="inline-flex items-center rounded-lg border border-gray-300 bg-white px-7 py-3.5 text-sm font-semibold text-gray-700 hover:bg-gray-50 active:scale-95 transition-all duration-200">
          {paginaInicio?.heroCta2Label ?? 'Ver exámenes'}
        </a>
        <a href={waHero} target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-2 rounded-lg bg-green-600 px-5 py-3.5 text-sm font-semibold text-white shadow-sm hover:bg-green-700 active:scale-95 transition-all duration-200">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          {paginaInicio?.heroCtaWaLabel ?? 'WhatsApp'}
        </a>
      </div>
      <!-- Key stats -->
      <dl class="mt-14 grid grid-cols-3 gap-4 border-t border-navy-100 pt-10 sm:grid-cols-3">
        <div class="text-center">
          <dt class="text-xs font-medium uppercase tracking-wide text-gray-500">Exámenes</dt>
          <dd class="mt-1 text-3xl font-bold text-navy-900">+{examenes.length}</dd>
        </div>
        <div class="text-center">
          <dt class="text-xs font-medium uppercase tracking-wide text-gray-500">Sedes</dt>
          <dd class="mt-1 text-3xl font-bold text-navy-900">{sedes.length}</dd>
        </div>
        <div class="text-center">
          <dt class="text-xs font-medium uppercase tracking-wide text-gray-500">Resultados</dt>
          <dd class="mt-1 text-3xl font-bold text-navy-900">Mismo día</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- 3. PILLARS STRIP -->
  <section aria-labelledby="pillars-heading" class="bg-navy-50 py-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <h2 id="pillars-heading" class="sr-only">Por qué CIC Laboratorios</h2>
      <ul role="list" class="grid grid-cols-2 gap-5 md:grid-cols-4">
        {pilares.map((pilar, i) => {
          const link = PILAR_LINKS[i];
          const content = (
            <>
              <svg class="h-7 w-7 text-navy-700" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={PILAR_SVGS[i]} />
              </svg>
              <strong class:list={['mt-3 block text-lg font-bold', link ? 'transition-colors duration-200 group-hover:text-navy-600' : 'text-navy-900']}>{pilar.titulo}</strong>
              <p class="mt-1 text-sm text-gray-600">{pilar.descripcion}</p>
            </>
          );
          return link ? (
            <li>
              <a href={link} class="group block h-full rounded-lg border border-navy-100 bg-white p-6 transition-shadow duration-200 hover:shadow-md">
                {content}
              </a>
            </li>
          ) : (
            <li class="rounded-lg border border-navy-100 bg-white p-6">{content}</li>
          );
        })}
      </ul>
    </div>
  </section>

  <!-- 4. AUDIENCE SEGMENTATION -->
  <section aria-labelledby="audience-heading" class="py-14">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <h2 id="audience-heading">¿Cómo podemos ayudarte?</h2>
      <div class="mt-8 grid grid-cols-1 gap-5 md:grid-cols-3">
        {audiencias.map((aud) => (
          <article class="relative flex flex-col rounded-lg border border-gray-200 p-6 transition-shadow duration-200 hover:shadow-md">
            {AUDIENCE_ICONS[aud.titulo] && (
              <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-lg bg-navy-50">
                <HeroIcon path={AUDIENCE_ICONS[aud.titulo]} class="h-6 w-6 text-navy-700" />
              </div>
            )}
            <h3 class="text-base">{aud.titulo}</h3>
            <p class="mt-2 flex-1 text-sm text-gray-600">{aud.descripcion}</p>
            <div class="mt-5 flex flex-col gap-2">
              {aud.links.map((lnk, li) => (
                <a
                  href={lnk.url}
                  class:list={[
                    'text-sm font-semibold transition-colors duration-200',
                    li === 0
                      ? 'text-navy-800 hover:text-navy-600 after:absolute after:inset-0 after:rounded-lg'
                      : 'relative z-10 text-gray-500 hover:text-navy-700',
                  ]}
                >
                  {lnk.label} →
                </a>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. SEDE MAP PREVIEW -->
  <section aria-labelledby="sedes-map-heading" class="bg-navy-50 py-14">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <h2 id="sedes-map-heading">{sedes.length} sedes en el Valle del Cauca</h2>

      <!-- Desktop: interactive SVG map + sidebar (md+) -->
      <div class="mt-6 hidden md:block">
        <SedeMap sedes={sedesParaMapa} showSidebar={true} client:visible />
      </div>

      <!-- Mobile: accordion by geographic zone -->
      <div class="mt-6 space-y-2 md:hidden">
        {[
          { label: 'Norte del Valle', sedes: zonas.norte },
          { label: 'Centro del Valle', sedes: zonas.centro },
          { label: 'Sur del Valle', sedes: zonas.sur },
        ].filter(z => z.sedes.length > 0).map(zona => (
          <details class="group rounded-xl border border-gray-200 bg-white overflow-hidden">
            <summary class="flex cursor-pointer list-none items-center justify-between px-4 py-3 text-sm font-semibold text-gray-800 select-none">
              <span>{zona.label}</span>
              <span class="flex items-center gap-2 text-gray-400">
                <span class="text-xs font-normal">{zona.sedes.length} sede{zona.sedes.length !== 1 ? 's' : ''}</span>
                <svg class="h-4 w-4 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                </svg>
              </span>
            </summary>
            <ul role="list" class="border-t border-gray-100">
              {zona.sedes.map((sede: Sede) => (
                <li class="border-b border-gray-50 last:border-0">
                  <a
                    href={`/sedes/${sede.slug}`}
                    class="flex items-start justify-between gap-3 px-4 py-3 text-sm transition-colors duration-150 hover:bg-navy-50"
                  >
                    <div>
                      <p class="font-medium text-gray-900">
                        {sede.ciudad}
                        {sede.esSedePrincipal && (
                          <span class="ml-2 inline-flex items-center rounded-full bg-green-100 px-1.5 py-0.5 text-[10px] font-medium text-green-700">Principal</span>
                        )}
                      </p>
                      <p class="mt-0.5 text-xs text-gray-400">{sede.direccion}</p>
                    </div>
                    <span class="mt-0.5 shrink-0 text-xs text-gray-300">→</span>
                  </a>
                </li>
              ))}
            </ul>
          </details>
        ))}
      </div>

      <a href="/sedes" class="mt-6 inline-block text-sm font-medium text-gray-700 hover:text-navy-700 transition-colors duration-200">Ver todas las sedes →</a>
    </div>
  </section>

  <!-- 6. EXAM CATEGORIES -->
  <section aria-labelledby="categorias-heading" class="py-14">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <h2 id="categorias-heading">Exámenes por categoría</h2>
      <ul role="list" class="mt-8 flex flex-wrap gap-2">
        {CATEGORIAS.map((cat, i) => (
          <li class={i >= MOBILE_CAT_LIMIT ? 'hidden sm:list-item' : ''}>
            <a href={`/examenes/categoria/${cat.slug}`}
               class="inline-flex items-center rounded-full border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:border-navy-200 hover:bg-navy-50 hover:text-navy-800 transition-colors duration-200">
              {cat.label}
            </a>
          </li>
        ))}
      </ul>
      <a href="/examenes" class="mt-6 inline-block text-sm font-semibold text-navy-800 hover:text-navy-600 transition-colors duration-200">Ver todos los exámenes →</a>
    </div>
  </section>

  <!-- 7. SERVICES -->
  <section aria-labelledby="servicios-heading" class="bg-gray-50 py-14">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <h2 id="servicios-heading">Nuestros servicios</h2>
      <ul role="list" class="mt-8 grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
        {servicios.map((servicio: CollectionEntry<'servicios'>) => (
          <li>
            <a href={`/servicios/${servicio.data.slug}`}
               class="group flex h-full flex-col rounded-lg border border-gray-200 bg-white p-6 transition-shadow duration-200 hover:shadow-md">
              {SERVICE_ICONS[servicio.data.slug] && (
                <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-navy-50">
                  <HeroIcon path={SERVICE_ICONS[servicio.data.slug]} class="h-6 w-6 text-navy-700" />
                </div>
              )}
              <h3 class="text-base transition-colors duration-200 group-hover:text-navy-700">
                {servicio.data.nombre}
              </h3>
              <p class="mt-2 flex-1 text-sm text-gray-600">{servicio.data.descripcion}</p>
              <span class="mt-4 inline-block text-sm font-semibold text-navy-800 transition-transform duration-200 group-hover:translate-x-1">
                Ver servicio →
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {testimonios.length > 0 && (
  <section aria-labelledby="testimonios-heading" class="py-12 bg-gray-50">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <h2 id="testimonios-heading">Lo que dicen nuestros pacientes</h2>
      <div class="mt-8 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {testimonios.map((t) => (
          <figure class="rounded-xl border border-gray-200 bg-white p-6">
            <blockquote class="text-gray-700 text-sm leading-relaxed">
              <p>"{t.texto}"</p>
            </blockquote>
            <figcaption class="mt-4 flex items-center gap-2">
              <div class="h-8 w-8 rounded-full bg-navy-100 flex items-center justify-center text-navy-700 text-sm font-semibold" aria-hidden="true">
                {t.nombre.charAt(0).toUpperCase()}
              </div>
              <div>
                <p class="text-sm font-medium text-gray-900">{t.nombre}</p>
                <p class="text-xs text-gray-500">{t.cargo ? `${t.cargo} · ` : ''}{t.ciudad}</p>
              </div>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>
  )}

  <!-- 8. QUALITY — trust anchor dark section -->
  <section aria-labelledby="calidad-heading" class="bg-navy-900 py-16 text-white">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-widest text-navy-200">Estándares de calidad</p>
        <h2 id="calidad-heading" class="mt-2 text-white">Calidad y tecnología al servicio de tu salud</h2>
      </div>
      <ul role="list" class="mt-10 grid grid-cols-1 gap-5 md:grid-cols-3">
        {calidad.map((item) => (
          <li class="flex flex-col rounded-lg border border-white/10 bg-white/5 p-6 backdrop-blur-sm">
            <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-full bg-navy-700">
              <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
            </div>
            <strong class="text-base font-semibold text-white">{item.titulo}</strong>
            <p class="mt-2 flex-1 text-sm text-navy-200">{item.descripcion}</p>
            {item.linkLabel && item.linkUrl && (
              <a href={item.linkUrl} class="mt-4 inline-block text-sm font-semibold text-navy-200 underline-offset-2 hover:text-white hover:underline transition-colors duration-200">
                {item.linkLabel} →
              </a>
            )}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- 9. CONVENIOS / ALIADOS -->
  <section aria-labelledby="aliados-heading" class="py-14">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <h2 id="aliados-heading">Convenios y aliados estratégicos</h2>
      {aliados.length > 0 && (
        <ul role="list" class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4">
          {aliados.map((aliado: CollectionEntry<'aliados'>) => (
            <li>
              {aliado.data.url ? (
                <a href={aliado.data.url} target="_blank" rel="noopener noreferrer">
                  <strong>{aliado.data.nombre}</strong>
                </a>
              ) : (
                <strong>{aliado.data.nombre}</strong>
              )}
            </li>
          ))}
        </ul>
      )}
      {/* TODO (content-needed): Add EPS/ARL logos once available */}
      <a
        href={`https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent('Quisiera información sobre convenios con CIC Laboratorios.')}`}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-6 inline-block text-sm font-medium text-gray-700 hover:text-navy-700 transition-colors duration-200"
      >
        Consultar convenios por WhatsApp →
      </a>
    </div>
  </section>

</BaseLayout>
