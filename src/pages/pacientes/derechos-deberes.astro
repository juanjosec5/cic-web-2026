---
/**
 * /pacientes/derechos-deberes — Patient rights and duties page.
 *
 * TODO (content-needed): Add official patient rights/duties text per
 *   Colombian health regulations (Resolución 13437 de 1991 and updates).
 * TODO (design-needed): Structured two-column layout: rights / duties.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Derechos y Deberes del Paciente"
  description="Conozca sus derechos y deberes como paciente de CIC Laboratorios, en cumplimiento de la normativa colombiana de salud."
>
  <h1>Derechos y deberes del paciente</h1>

  <section aria-labelledby="derechos-heading">
    <h2 id="derechos-heading">Sus derechos</h2>
    <!-- TODO (content-needed): Add full list of patient rights per Colombian health law -->
    <ol>
      <li>Recibir atención con calidad, calidez y respeto a su dignidad.</li>
      <li>Obtener información clara y comprensible sobre su diagnóstico.</li>
      <li>Mantener la confidencialidad de su información de salud.</li>
      <li>[ Derecho 4 — pendiente ]</li>
    </ol>
  </section>

  <section aria-labelledby="deberes-heading">
    <h2 id="deberes-heading">Sus deberes</h2>
    <!-- TODO (content-needed): Add full list of patient duties -->
    <ol>
      <li>Proporcionar información veraz sobre su estado de salud.</li>
      <li>Seguir las instrucciones de preparación indicadas.</li>
      <li>Tratar con respeto al personal de salud.</li>
      <li>[ Deber 4 — pendiente ]</li>
    </ol>
  </section>
</BaseLayout>
