---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import HeroIcon from '@/components/HeroIcon.astro';
import { SITE_CONFIG } from '@/lib/config';

const waFaq = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent('Tengo una pregunta sobre los servicios de CIC Laboratorios.')}`;

const GRUPO_ICONS: Record<string, string> = {
  'general':    'M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z',
  'examenes':   'M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15M14.25 3.104c.251.023.501.05.75.082M19.8 15a2.25 2.25 0 0 1 .244 1.028l-.001.002a2.25 2.25 0 0 1-2.244 2.22H6.2a2.25 2.25 0 0 1-2.244-2.22l-.001-.002A2.25 2.25 0 0 1 4.2 15m15.6 0-3.675-1.845a2.25 2.25 0 0 0-2.25 0L9.75 15M8.25 2.25h7.5',
  'domicilio':  'M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25',
  'resultados': 'M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z',
};

const grupos = [
  {
    id: 'general',
    titulo: 'General',
    faqs: [
      {
        pregunta: '¿Necesito cita previa para tomar mis muestras?',
        respuesta: 'No. En todas nuestras sedes atendemos sin cita previa.',
      },
      {
        pregunta: '¿Cuándo están listos mis resultados?',
        // TODO (content-needed): Confirm exact delivery times per exam category
        respuesta: 'La mayoría de exámenes están listos el mismo día. Casos de alta complejidad pueden tomar más tiempo — te lo indicaremos al momento de la toma.',
      },
      {
        pregunta: '¿Qué debo llevar para tomarme una muestra?',
        // TODO (content-needed): Confirm required documents
        respuesta: 'Documento de identidad y la orden médica si la tiene. Para algunos exámenes puede ser necesaria la orden.',
      },
    ],
  },
  {
    id: 'examenes',
    titulo: 'Exámenes',
    faqs: [
      {
        pregunta: '¿Cómo puedo verificar la autenticidad de mis resultados?',
        respuesta: 'Cada resultado incluye un código QR único. Escanéelo o ingrese su código en nuestro <a href="https://r2.ciclaboratorios.com:8081/VerificadorResultadosJavaEnvironment/servlet/com.verificadorresultados.webpanelprincipal" target="_blank" rel="noopener noreferrer" class="text-red-600 hover:text-red-700 underline">portal de verificación</a>.',
      },
      {
        pregunta: '¿Qué exámenes requieren ayuno?',
        respuesta: 'Los más comunes son glucosa, perfil lipídico y algunas pruebas hormonales. En la página de cada examen encontrará las instrucciones específicas.',
      },
      {
        pregunta: '¿Puedo hacerme exámenes sin orden médica?',
        // TODO (content-needed): Confirm policy on exams without doctor's order
        respuesta: 'Sí, la mayoría de exámenes de rutina pueden solicitarse sin orden médica. Consulte con nuestro personal.',
      },
    ],
  },
  {
    id: 'domicilio',
    titulo: 'Servicio a domicilio',
    faqs: [
      {
        pregunta: '¿Ofrecen servicio a domicilio?',
        respuesta: 'Sí, disponible en Buga y Tuluá. Contáctanos por WhatsApp para coordinar.',
      },
      {
        pregunta: '¿Tiene costo adicional el servicio a domicilio?',
        // TODO (content-needed): Confirm current pricing for each sede
        respuesta: 'En Buga el servicio es gratuito para pedidos desde $50.000. Consulte con su sede más cercana.',
      },
      {
        pregunta: '¿Con cuánta anticipación debo solicitar el domicilio?',
        // TODO (content-needed): Confirm scheduling lead time
        respuesta: 'Recomendamos solicitarlo con al menos un día de anticipación para garantizar disponibilidad.',
      },
    ],
  },
  {
    id: 'resultados',
    titulo: 'Resultados',
    faqs: [
      {
        pregunta: '¿Cómo recibo mis resultados?',
        // TODO (content-needed): Confirm delivery channels (digital, WhatsApp, in-person)
        respuesta: 'Los resultados pueden recogerse en sede o enviarse digitalmente. Pregúntele al personal al momento de la toma.',
      },
      {
        pregunta: '¿Por cuánto tiempo guarda el laboratorio mis resultados?',
        // TODO (content-needed): Confirm data retention policy
        respuesta: '[ Pendiente — consulte con nuestro personal ]',
      },
    ],
  },
] as const;
---

<BaseLayout
  title="Preguntas Frecuentes"
  description="Respuestas a las preguntas más frecuentes sobre los servicios, resultados y preparación en CIC Laboratorios."
>
  <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6">

    <Breadcrumb items={[{ label: 'Inicio', href: '/' }, { label: 'Pacientes', href: '/pacientes/preguntas-frecuentes' }, { label: 'Preguntas frecuentes' }]} />

    <header>
      <h1>Preguntas frecuentes</h1>
      <p>Todo lo que necesita saber antes de su visita a CIC Laboratorios.</p>
    </header>

    <div class="mt-10 space-y-12">
      {grupos.map((grupo) => (
        <section id={grupo.id} aria-labelledby={`${grupo.id}-heading`}>
          <h2 id={`${grupo.id}-heading`} class="flex items-center gap-2">
            <HeroIcon path={GRUPO_ICONS[grupo.id]} class="h-6 w-6 shrink-0 text-red-600" />
            {grupo.titulo}
          </h2>
          <div class="mt-6 space-y-3">
            {grupo.faqs.map((faq) => (
              <details class="group rounded-lg border border-gray-200 overflow-hidden">
                <summary class="flex cursor-pointer list-none items-center justify-between p-4 font-medium text-gray-900 hover:bg-gray-50 transition-colors duration-200">
                  <span>{faq.pregunta}</span>
                  <svg class="h-5 w-5 shrink-0 text-gray-500 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                  </svg>
                </summary>
                {/* set:html is intentional: respuesta is hardcoded in this file and may contain inline <a> links.
                    If FAQs are ever moved to a CMS, sanitize HTML (DOMPurify) or use structured link fields instead. */}
                <p class="border-t border-gray-100 px-4 py-4 text-sm text-gray-600" set:html={faq.respuesta} />
              </details>
            ))}
          </div>
        </section>
      ))}
    </div>

    <section aria-labelledby="mas-preguntas-heading" class="mt-12">
      <h2 id="mas-preguntas-heading">¿No encontraste tu respuesta?</h2>
      <p class="mt-4">Escríbenos directamente:</p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href={waFaq} target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-2 rounded-lg bg-green-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-green-700 active:scale-95 transition-all duration-200">
          Preguntar por WhatsApp
        </a>
        <a href="/contacto"
           class="inline-flex items-center rounded-lg border border-gray-300 bg-white px-5 py-2.5 text-sm font-semibold text-gray-700 hover:bg-gray-50 active:scale-95 transition-all duration-200">
          Ir a Contacto
        </a>
      </div>
    </section>

  </div>
</BaseLayout>
