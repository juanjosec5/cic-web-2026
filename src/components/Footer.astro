---
const currentYear = new Date().getFullYear();

const siteLinks = [
  { label: 'Sedes', href: '/sedes' },
  { label: 'Exámenes', href: '/examenes' },
  { label: 'Servicios', href: '/servicios' },
  { label: 'Empresas', href: '/empresas' },
  { label: 'Nosotros', href: '/nosotros' },
  { label: 'Preparación de exámenes', href: '/pacientes/preparacion' },
  { label: 'Preguntas frecuentes', href: '/pacientes/preguntas-frecuentes' },
  { label: 'Contacto', href: '/contacto' },
];
---

<footer class="mt-auto bg-gray-900 text-gray-300">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-3">

      <!-- Contact block -->
      <div>
        <h2 class="mb-4 font-semibold text-white">CIC Laboratorios</h2>
        <address class="space-y-1 text-sm not-italic leading-relaxed">
          <p>Calle 5 # 14-23, Centro</p>
          <p>Guadalajara de Buga, Valle del Cauca</p>
          <p>
            <a href="tel:+576022280000" class="transition-colors hover:text-white">
              Tel: 602 228 0000
            </a>
          </p>
          <p>
            <a href="mailto:buga@ciclaboratorios.com" class="transition-colors hover:text-white">
              buga@ciclaboratorios.com
            </a>
          </p>
        </address>
      </div>

      <!-- Sitemap -->
      <nav aria-label="Mapa del sitio">
        <h2 class="mb-4 font-semibold text-white">Mapa del sitio</h2>
        <ul role="list" class="space-y-2 text-sm">
          {siteLinks.map((link) => (
            <li>
              <a href={link.href} class="transition-colors hover:text-white">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Social -->
      <div>
        <h2 class="mb-4 font-semibold text-white">Síguenos</h2>
        <ul role="list" class="space-y-2 text-sm">
          <li>
            <a href="#" class="transition-colors hover:text-white">
              Facebook
            </a>
          </li>
          <li>
            <a href="#" class="transition-colors hover:text-white">
              Instagram
            </a>
          </li>
          <li>
            <a href="#" class="transition-colors hover:text-white">
              LinkedIn
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Copyright bar -->
  <div class="border-t border-gray-800">
    <div class="mx-auto max-w-7xl px-4 py-4 sm:px-6">
      <p class="text-center text-sm text-gray-500">
        &copy; {currentYear} CIC Laboratorios. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
