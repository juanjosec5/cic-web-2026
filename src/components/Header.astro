---
const pathname = Astro.url.pathname;

type NavChild = { label: string; href: string };
type NavLink = {
  label: string;
  href: string;
  external?: boolean;
  children?: NavChild[];
};

const navLinks: NavLink[] = [
  { label: 'Inicio', href: '/' },
  { label: 'Sedes', href: '/sedes' },
  {
    label: 'Exámenes',
    href: '/examenes',
    children: [
      { label: 'Catálogo de exámenes', href: '/examenes' },
      { label: 'Paquetes y perfiles', href: '/examenes/perfiles' },
    ],
  },
  { label: 'Servicios', href: '/servicios' },
  { label: 'Empresas', href: '/empresas' },
  { label: 'Nosotros', href: '/nosotros' },
  {
    label: 'Resultados',
    href: 'https://resultados.ciclaboratorios.com',
    external: true,
  },
];

function isActive(link: NavLink) {
  if (link.children) {
    return link.children.some(
      (c) => pathname === c.href || (c.href !== '/' && pathname.startsWith(c.href))
    );
  }
  return pathname === link.href || (link.href !== '/' && pathname.startsWith(link.href));
}
---

<header class="sticky top-0 z-50 bg-white border-b border-gray-200">
  <div class="mx-auto max-w-7xl px-4 sm:px-6">
    <div class="flex items-center justify-between py-4">

      <!-- Logo -->
      <a href="/" class="shrink-0 max-w-[180px]" aria-label="CIC Laboratorios — Inicio">
        <img src="/images/logo/logo.svg" alt="CIC Laboratorios" class="h-9 w-full" />
      </a>

      <!-- Desktop nav (hidden on mobile) -->
      <nav class="hidden md:flex" aria-label="Navegación principal">
        <ul role="list" class="flex items-center gap-1">
          {navLinks.map((link) => (
            <li class={link.children ? 'relative group' : ''}>
              {link.children ? (
                <>
                  <!-- Dropdown trigger -->
                  <button
                    type="button"
                    class:list={[
                      'flex items-center gap-1 rounded-md px-3 py-2 text-sm font-medium transition-colors',
                      isActive(link)
                        ? 'bg-red-50 text-red-700 font-semibold'
                        : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900',
                    ]}
                    aria-haspopup="true"
                  >
                    {link.label}
                    <svg class="h-3.5 w-3.5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                    </svg>
                  </button>
                  <!-- Dropdown panel -->
                  <ul
                    role="list"
                    class="absolute left-0 top-full z-50 mt-1 hidden min-w-[200px] rounded-xl border border-gray-200 bg-white py-1 shadow-lg group-hover:block"
                  >
                    {link.children.map((child) => (
                      <li>
                        <a
                          href={child.href}
                          class:list={[
                            'block px-4 py-2.5 text-sm font-medium transition-colors',
                            pathname === child.href
                              ? 'bg-red-50 text-red-700'
                              : 'text-gray-700 hover:bg-gray-50 hover:text-gray-900',
                          ]}
                        >
                          {child.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </>
              ) : (
                <a
                  href={link.href}
                  class:list={[
                    'block rounded-md px-3 py-2 text-sm font-medium transition-colors',
                    isActive(link)
                      ? 'bg-red-50 text-red-700 font-semibold'
                      : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900',
                  ]}
                  {...(link.external
                    ? { target: '_blank', rel: 'noopener noreferrer' }
                    : {})}
                >
                  {link.label}
                </a>
              )}
            </li>
          ))}
        </ul>
      </nav>

      <!-- Hamburger button (hidden on desktop) -->
      <button
        id="nav-toggle"
        type="button"
        aria-controls="mobile-nav-panel"
        aria-expanded="false"
        aria-label="Abrir menú"
        class="-mr-2 rounded-md p-2 text-gray-500 transition-colors hover:bg-gray-100 hover:text-gray-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-red-500 md:hidden"
      >
        <!-- Menu icon -->
        <svg
          id="icon-menu"
          class="size-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <!-- Close icon -->
        <svg
          id="icon-close"
          class="size-6 hidden"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav panel — slide-in dropdown -->
  <div
    id="mobile-nav-panel"
    class="border-t border-gray-200 bg-white md:hidden"
    aria-hidden="true"
  >
    <nav aria-label="Menú móvil">
      <ul role="list" class="space-y-1 px-4 py-3">
        {navLinks.map((link) => (
          <li>
            {link.children ? (
              <>
                <span
                  class:list={[
                    'block rounded-md px-3 py-2 text-base font-medium',
                    isActive(link) ? 'text-red-700 font-semibold' : 'text-gray-500',
                  ]}
                >
                  {link.label}
                </span>
                <ul role="list" class="ml-4 mt-1 space-y-1">
                  {link.children.map((child) => (
                    <li>
                      <a
                        href={child.href}
                        class:list={[
                          'block rounded-md px-3 py-2 text-sm font-medium transition-colors',
                          pathname === child.href
                            ? 'bg-red-50 text-red-700 font-semibold'
                            : 'text-gray-700 hover:bg-gray-100 hover:text-gray-900',
                        ]}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </>
            ) : (
              <a
                href={link.href}
                class:list={[
                  'block rounded-md px-3 py-2 text-base font-medium transition-colors',
                  isActive(link)
                    ? 'bg-red-50 text-red-700 font-semibold'
                    : 'text-gray-700 hover:bg-gray-100 hover:text-gray-900',
                ]}
                {...(link.external
                  ? { target: '_blank', rel: 'noopener noreferrer' }
                  : {})}
              >
                {link.label}
              </a>
            )}
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  #mobile-nav-panel {
    max-height: 0;
    overflow: hidden;
    transition: max-height 300ms ease-in-out;
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle') as HTMLButtonElement | null;
  const panel = document.getElementById('mobile-nav-panel') as HTMLElement | null;
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  function openNav() {
    if (!panel) return;
    panel.style.maxHeight = panel.scrollHeight + 'px';
    panel.setAttribute('aria-hidden', 'false');
    iconMenu?.classList.add('hidden');
    iconClose?.classList.remove('hidden');
    toggle?.setAttribute('aria-expanded', 'true');
    toggle?.setAttribute('aria-label', 'Cerrar menú');
  }

  function closeNav() {
    if (!panel) return;
    panel.style.maxHeight = '0';
    panel.setAttribute('aria-hidden', 'true');
    iconMenu?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
    toggle?.setAttribute('aria-label', 'Abrir menú');
  }

  toggle?.addEventListener('click', () => {
    toggle.getAttribute('aria-expanded') === 'true' ? closeNav() : openNav();
  });

  // Reset mobile state when viewport reaches desktop width
  window.matchMedia('(min-width: 768px)').addEventListener('change', (e) => {
    if (e.matches) closeNav();
  });
</script>
