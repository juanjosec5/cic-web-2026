---
/**
 * BaseLayout.astro
 * Root layout used by all pages. Renders <html>, SEO head, Header,
 * default slot, Footer, and the WhatsApp floating island.
 *
 * TODO (design-needed): Add skip-to-main-content accessibility link.
 * TODO (design-needed): Add cookie consent banner.
 * TODO (content-needed): Replace hardcoded WhatsApp phone with env var or
 *   sede principal data from collection.
 */
import SEO from '@/components/SEO.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import WhatsAppFloating from '@/components/islands/WhatsAppFloating.vue';
import { SITE_CONFIG } from '@/lib/config';
import '@/styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown>;
}

const { title, description, canonical, ogImage, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      jsonLd={jsonLd}
    />
  </head>
  <body class="flex min-h-svh flex-col bg-white text-gray-900">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-2 focus:top-2 focus:z-50 focus:rounded focus:bg-red-600 focus:px-4 focus:py-2 focus:text-white"
    >
      Ir al contenido principal
    </a>
    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
    <WhatsAppFloating phone={SITE_CONFIG.whatsapp} client:load />
  </body>
</html>
