---
/**
 * SedeLayout.astro
 * Layout for individual sede pages. Extends BaseLayout and injects
 * MedicalBusiness JSON-LD automatically from the sede data.
 *
 * TODO (design-needed): Add sede hero image / photo gallery section.
 */
import BaseLayout from './BaseLayout.astro';
import { buildSedeJsonLd, horarioToOpeningHours } from '@/lib/seo';
import type { Sede } from '@/sanity/types';

interface Props {
  sede: Sede;
  description?: string;
}

const { sede, description } = Astro.props;

const openingHours = horarioToOpeningHours(sede.horario);

const jsonLd = buildSedeJsonLd({
  nombre: sede.nombre,
  descripcion: description,
  direccion: sede.direccion,
  ciudad: sede.ciudad,
  telefono: sede.telefono,
  lat: sede.lat ?? undefined,
  lng: sede.lng ?? undefined,
  url: `${Astro.site}sedes/${sede.slug}`,
  openingHours,
});
---

<BaseLayout
  title={`Laboratorio Clínico en ${sede.ciudad} — ${sede.nombre} | CIC Laboratorios`}
  description={description ?? `Sede de CIC Laboratorios en ${sede.ciudad}. Exámenes clínicos, resultados el mismo día.`}
  jsonLd={jsonLd}
  whatsappMessage={`Hola, quisiera información sobre la sede ${sede.nombre} en ${sede.ciudad}.`}
>
  <slot />
</BaseLayout>
